// ── Onboarding ─────────────────────────────────────────────────────────────
async function runOnboardingChecks() {
  // Check server health
  try {
    const r = await fetch(`${API}/health`);
    const d = await r.json();
    document.getElementById('check-server').textContent = `✅ API server running (${d.version||'v?'})`;
    document.getElementById('check-server').className = 'check-item ok';
  } catch(e) {
    document.getElementById('check-server').textContent = `❌ API server not responding — run start.sh`;
    document.getElementById('check-server').className = 'check-item fail';
  }

  // Check Ollama via /system/vram (ollama must be running for GPU info) + /models/forge-models
  try {
    const fmResp = await fetch(`${API}/models/forge-models`);
    const fm = await fmResp.json();
    const forgeModels = fm.allModels || [];
    const hasModel = forgeModels.some(m =>
      (typeof m === 'string' ? m : (m.name || '')).includes('phi3.5-forge') ||
      (typeof m === 'string' ? m : (m.name || '')).includes('phi3.5')
    );
    document.getElementById('check-ollama').textContent = `✅ Ollama running`;
    document.getElementById('check-ollama').className = 'check-item ok';
    document.getElementById('check-model').textContent = hasModel
      ? `✅ phi3.5-forge model available`
      : `❌ phi3.5-forge not found — run: ollama pull phi3.5`;
    document.getElementById('check-model').className = 'check-item ' + (hasModel ? 'ok' : 'fail');
  } catch(e) {
    // Fall back to /models
    try {
      const r = await fetch(`${API}/models`);
      const d = await r.json();
      const models = (d.models || []).map(m => typeof m === 'string' ? m : m.name || '');
      const hasModel = models.some(m => m.includes('phi3.5') || m.includes('forge'));
      document.getElementById('check-ollama').textContent = `✅ Ollama running (${models.length} models)`;
      document.getElementById('check-ollama').className = 'check-item ok';
      document.getElementById('check-model').textContent = hasModel
        ? `✅ phi3.5-forge model available`
        : `❌ phi3.5-forge not found — run: ollama pull phi3.5`;
      document.getElementById('check-model').className = 'check-item ' + (hasModel ? 'ok' : 'fail');
    } catch(e2) {
      document.getElementById('check-ollama').textContent = `❌ Ollama not running — run: ollama serve`;
      document.getElementById('check-ollama').className = 'check-item fail';
      document.getElementById('check-model').textContent = `❌ Cannot check (Ollama offline)`;
      document.getElementById('check-model').className = 'check-item fail';
    }
  }

  // Check VRAM — usedMB < 3500 is considered OK
  try {
    const r = await fetch(`${API}/system/vram`);
    const v = await r.json();
    if (v.available) {
      const free = v.totalMB - v.usedMB;
      const vramOk = v.usedMB < 3500;
      document.getElementById('check-vram').textContent = vramOk
        ? `✅ VRAM ok: ${v.usedMB}/${v.totalMB}MB used (${free}MB free)`
        : `⚠️ VRAM tight: ${v.usedMB}MB used — close other GPU apps`;
      document.getElementById('check-vram').className = 'check-item ' + (vramOk ? 'ok' : 'fail');
    } else {
      document.getElementById('check-vram').textContent = `⚠️ GPU stats unavailable (nvidia-smi not found)`;
      document.getElementById('check-vram').className = 'check-item ok';
    }
  } catch(e) {
    document.getElementById('check-vram').textContent = `⚠️ Could not check VRAM`;
    document.getElementById('check-vram').className = 'check-item ok';
  }
}

