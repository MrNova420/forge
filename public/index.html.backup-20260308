      <div style="margin-bottom:12px">
        <label style="font-size:11px;color:var(--text3);display:block;margin-bottom:4px">Project Name</label>
        <input id="wiz-name" class="chat-input" style="width:100%;box-sizing:border-box;resize:none;height:36px;padding:8px 10px" placeholder="e.g. notes-api, blog-cms, task-cli">
      </div>
      <div style="margin-bottom:16px">
        <label style="font-size:11px;color:var(--text3);display:block;margin-bottom:4px">Description</label>
        <textarea id="wiz-desc" class="chat-input" rows="3" style="width:100%;box-sizing:border-box" placeholder="What does this project do? Be specific — agents use this to plan the architecture."></textarea>
      </div>
      <button class="btn btn-primary" style="width:100%" onclick="wizardNext(1)">Next →</button>
