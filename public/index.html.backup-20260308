}

async function saveEditorFile() {
  if (!editorCurrentFile || !editorCurrentProject) return;
  const content = document.getElementById('file-editor').value;
  try {
    await api('PUT', `/project/${editorCurrentProject}/file`, { content, path: editorCurrentFile });
    toast('💾 File saved!', 'success');
  } catch(e) { toast('Save failed: ' + e.message, 'error'); }
}

async function runEditorAction(action) {
  const code = document.getElementById('file-editor').value;
  if (!code.trim()) return toast('No code to analyze', 'error');
  const resultDiv = document.getElementById('editor-result');
  resultDiv.style.display = 'block';
  resultDiv.textContent = `⟳ Running ${action}…`;
  const endpointMap = { explain: '/code/explain', fix: '/code/fix', test: '/code/generate-tests', refactor: '/code/refactor' };
  const endpoint = endpointMap[action];
  const f = editorCurrentFile || '';
  const lang = f.endsWith('.py') ? 'python' : f.endsWith('.ts') ? 'typescript' : f.endsWith('.rs') ? 'rust' : 'javascript';
  try {
    const r = await api('POST', endpoint, { code, lang, filename: editorCurrentFile });
    const result = r.explanation || r.fixed || r.tests || r.refactored || r.result || JSON.stringify(r, null, 2);
    resultDiv.textContent = result;
    if (action !== 'explain' && result.trim()) {
      if (confirm(`Apply ${action} result to editor?`)) {
        document.getElementById('file-editor').value = result;
        resultDiv.style.display = 'none';
        toast(`✅ ${action} applied!`, 'success');
      }
    }
  } catch(e) { resultDiv.textContent = '❌ Error: ' + e.message; }
}

