// ── Syntax Highlighting ─────────────────────────────────────────────────────
function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#x27;'); }
function highlightCode(code, filename) {
  const ext = (filename||'').split('.').pop().toLowerCase();
  if (!['js','ts','json','sh','md'].includes(ext)) return escapeHtml(code);
  let h = escapeHtml(code);
  if (ext === 'json') {
    h = h.replace(/(&quot;[^&]*&quot;)\s*:/g, '<span class="code-keyword">$1</span>:')
         .replace(/:\s*(&quot;[^&]*&quot;)/g, ': <span class="code-string">$1</span>');
    return h;
  }
  // JS/TS/SH
  h = h.replace(/(\/\/[^\n]*)/g, '<span class="code-comment">$1</span>');
  h = h.replace(/\b(const|let|var|function|class|return|if|else|for|while|async|await|require|module|exports|import|from|new|this|try|catch|throw)\b/g, '<span class="code-keyword">$1</span>');
  h = h.replace(/(&quot;[^&]*&quot;|&#x27;[^&]*&#x27;|`[^`]*`)/g, '<span class="code-string">$1</span>');
  h = h.replace(/\b(\d+)\b/g, '<span class="code-number">$1</span>');
  return h;
}

// ── Chat History Persistence ────────────────────────────────────────────────
function getChatHistory(projectId) {
  const key = projectId ? `forge_chat_${projectId}` : 'forge_chat';
  try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch { return []; }
}

function saveChatMessage(projectId, role, content) {
  const key = projectId ? `forge_chat_${projectId}` : 'forge_chat';
  const history = getChatHistory(projectId);
  history.push({ role, content, ts: Date.now() });
  if (history.length > 50) history.splice(0, history.length - 50);
  localStorage.setItem(key, JSON.stringify(history));
}

function loadChatHistory(projectId) {
  const history = getChatHistory(projectId);
  const messagesEl = document.getElementById('chat-messages');
  if (!messagesEl) return;
  messagesEl.innerHTML = '';
  if (!history.length) {
    messagesEl.innerHTML = '<div class="chat-msg system">Ask any agent a question or request code.</div>';
    return;
  }
  for (const msg of history) {
    const div = document.createElement('div');
    div.className = `chat-msg ${msg.role === 'user' ? 'user-msg' : 'assist-msg'}`;
    div.innerHTML = `<div class="msg-avatar">${msg.role === 'user' ? '👤' : '⚡'}</div><div class="msg-content">${escapeHtml(msg.content)}</div>`;
    messagesEl.appendChild(div);
  }
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function saveChatHistory() {
  // Legacy: save current DOM messages to project-scoped key
  const projectId = selectedProject?.id || null;
  const key = projectId ? `forge_chat_${projectId}` : 'forge_chat';
  const msgs = document.getElementById('chat-messages');
  const items = [];
  msgs.querySelectorAll('.chat-msg').forEach(el => {
    items.push({ className: el.className, html: el.innerHTML });
  });
  localStorage.setItem(key, JSON.stringify(items.slice(-50)));
}

function restoreChatHistory() {
  loadChatHistory(selectedProject?.id || null);
}

function clearChatHistory() {
  const projectId = selectedProject?.id || null;
  const key = projectId ? `forge_chat_${projectId}` : 'forge_chat';
  localStorage.removeItem(key);
  const msgs = document.getElementById('chat-messages');
  msgs.innerHTML = '<div class="chat-msg system">Ask any agent a question or request code.</div>';
}

