const QUICK=['Explain my current project','What tasks are done?','Review the latest code','Suggest improvements','What should I build next?']

function Chat() {
  const [msgs,setMsgs]=useState([{role:'assistant',content:"Hi! I'm Forge — your local AI assistant. Ask me anything about your projects, code, or request pipeline actions."}])
  const [input,setInput]=useState('')
  const [loading,setLoading]=useState(false)
  const [model,setModel]=useState('qwen2.5-coder:3b')
  const bottomRef=useRef(null)
  useEffect(()=>{ bottomRef.current?.scrollIntoView({behavior:'smooth'}) },[msgs,loading])
  const send=async(text)=>{
    const msg=text||input.trim(); if(!msg||loading) return
    setInput(''); setMsgs(m=>[...m,{role:'user',content:msg}]); setLoading(true)
    // streaming placeholder
    const streamId = Date.now()
    setMsgs(m=>[...m,{role:'assistant',content:'',streaming:true,id:streamId,model}])
    try {
      const r=await fetch('/chat/stream',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,model})})
      const reader=r.body.getReader(); const dec=new TextDecoder(); let buf=''
      while(true){
        const {done,value}=await reader.read(); if(done) break
        buf+=dec.decode(value,{stream:true})
        const lines=buf.split('\n'); buf=lines.pop()
        for(const line of lines){
          if(!line.startsWith('data:')) continue
          try{
            const d=JSON.parse(line.slice(5).trim())
            if(d.token) setMsgs(m=>m.map(x=>x.id===streamId?{...x,content:x.content+d.token}:x))
            if(d.done)  setMsgs(m=>m.map(x=>x.id===streamId?{...x,streaming:false}:x))
          }catch{}
        }
      }
    } catch { setMsgs(m=>m.map(x=>x.id===streamId?{...x,content:'⚠️ Connection error',streaming:false}:x)) }
    finally { setLoading(false) }
  }
  const MODELS=['qwen2.5-coder:3b','deepseek-r1:1.5b','deepseek-coder:1.3b']
  return (
    <div className="flex flex-col" style={{minHeight:'calc(100vh - 8rem)'}}>
      <div className="flex items-start justify-between mb-4 flex-wrap gap-2">
        <div>
          <BlurText text="Chat with Forge" className="text-2xl font-bold text-white" animateBy="words" delay={60}/>
          <p className="text-sm text-zinc-500 mt-0.5">Powered by your local models — 100% private</p>
        </div>
        <div className="flex gap-1.5 flex-wrap">
          {MODELS.map(m=>(
            <button key={m} onClick={()=>setModel(m)}
              className={`px-2.5 py-1 rounded-lg text-[11px] font-medium border transition-all ${
                model===m ? 'bg-violet-500/15 text-violet-300 border-violet-500/25' : 'text-zinc-500 border-white/[0.06] hover:text-zinc-300'
              }`}>{m.split(':')[0]}</button>
          ))}
        </div>
      </div>
      <div className="flex gap-2 flex-wrap mb-4">
        {QUICK.map(q=><button key={q} onClick={()=>send(q)} className="px-3 py-1.5 rounded-lg text-xs text-zinc-400 transition-all" style={{background:'rgba(255,255,255,0.025)',border:'1px solid rgba(255,255,255,0.06)'}}>{q}</button>)}
      </div>
      <div className="flex-1 overflow-y-auto forge-scroll space-y-4 mb-4 pr-1" style={{maxHeight:'55vh'}}>
        {msgs.map((m,i)=>(
          <div key={i} className={`flex gap-3 ${m.role==='user'?'flex-row-reverse':''}`}>
            <div className={`w-7 h-7 rounded-lg flex-shrink-0 flex items-center justify-center text-xs font-bold mt-0.5 ${m.role==='user'?'text-violet-300':'text-zinc-400'}`}
              style={{background:m.role==='user'?'rgba(124,58,237,0.25)':'rgba(255,255,255,0.04)'}}>
              {m.role==='user'?'U':'F'}
            </div>
            <div className={`max-w-[80%] rounded-2xl px-4 py-3 text-sm leading-relaxed ${m.role==='user'?'rounded-tr-sm':'rounded-tl-sm'}`}
              style={m.role==='user'
                ? {background:'rgba(124,58,237,0.15)',color:'white',border:'1px solid rgba(124,58,237,0.2)'}
                : {background:'rgba(255,255,255,0.04)',color:'#d4d4d8',border:'1px solid rgba(255,255,255,0.07)'}}>
              <pre className="whitespace-pre-wrap font-sans">{m.content}{m.streaming&&<span className="inline-block w-0.5 h-4 bg-violet-400 ml-0.5 animate-pulse align-text-bottom"/>}</pre>
              {m.model && !m.streaming && <span className="block text-[10px] text-zinc-600 mt-1.5">{m.model}</span>}
            </div>
          </div>
        ))}
        {loading && !msgs.find(m=>m.streaming) && (
          <div className="flex gap-3">
            <div className="w-7 h-7 rounded-lg flex items-center justify-center text-xs text-zinc-400" style={{background:'rgba(255,255,255,0.04)'}}>F</div>
            <div className="rounded-2xl rounded-tl-sm px-4 py-3" style={{background:'rgba(255,255,255,0.04)',border:'1px solid rgba(255,255,255,0.07)'}}>
              <div className="flex gap-1.5 items-center">
                {[0,150,300].map(d=><div key={d} className="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style={{animationDelay:`${d}ms`}}/>)}
                <span className="text-xs text-zinc-600 ml-2">Thinking...</span>
              </div>
            </div>
          </div>
        )}
        <div ref={bottomRef}/>
      </div>
      <div className="relative">
        <input value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==='Enter'&&!e.shiftKey&&send()}
          placeholder="Ask anything — code, projects, architecture..."
          className="w-full rounded-2xl px-5 py-3.5 pr-14 text-sm text-white placeholder-zinc-600 focus:outline-none transition-all"
          style={{background:'rgba(255,255,255,0.04)',border:'1px solid rgba(255,255,255,0.08)'}}
          onFocus={e=>{e.target.style.borderColor='rgba(139,92,246,0.4)';e.target.style.background='rgba(124,58,237,0.04)'}}
          onBlur={e=>{e.target.style.borderColor='rgba(255,255,255,0.08)';e.target.style.background='rgba(255,255,255,0.04)'}}
        />
        <button onClick={()=>send()} disabled={loading||!input.trim()}
          className="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-8 rounded-xl flex items-center justify-center text-sm transition-all disabled:opacity-30"
          style={{background:'rgba(124,58,237,0.3)',color:'#c4b5fd'}}>↑</button>
      </div>
    </div>
  )
}

