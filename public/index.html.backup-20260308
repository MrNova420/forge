</div>

<!-- Task Detail Modal -->
<div id="task-detail-overlay" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:1000;overflow:auto;">
  <div style="background:#1a1a2e;margin:40px auto;max-width:900px;border-radius:8px;padding:24px;border:1px solid #333;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <h3 id="task-detail-title" style="color:#e0e0e0;margin:0;"></h3>
      <button onclick="closeTaskDetail()" style="background:none;border:none;color:#888;font-size:20px;cursor:pointer;">✕</button>
    </div>
    <div id="task-detail-meta" style="color:#888;font-size:12px;margin-bottom:16px;"></div>
    <div id="task-detail-pipeline" style="color:#ccc;font-size:13px;"></div>
  </div>
</div>

<!-- Toasts -->
<div class="toast-container" id="toasts"></div>

<script>
const API = '';  // same origin
let projects = [], tasks = [], stats = {}, selectedProject = null, currentView = 'overview', currentLog = 'runner', currentBrowseProject = null, selectedAgentRole = 'coder', currentSearchSource = 'all';
let chatHistory = [];
let sseActive = false;
let _sseConnection = null;

// ── SSE Live Event Stream ──────────────────────────────────────────────────
function initSSE() {
  // Close any existing connection before creating a new one to avoid duplicate events
  if (_sseConnection) { try { _sseConnection.close(); } catch(e) {} _sseConnection = null; }
  const es = new EventSource('/events');
  _sseConnection = es;
  es.addEventListener('connected', () => {
    sseActive = true;
    document.getElementById('sse-dot').classList.remove('inactive');
    document.getElementById('live-panel-dot')?.classList.remove('inactive');
    document.getElementById('live-event-text').textContent = '● Live stream active';
    const pill = document.getElementById('sse-live-pill');
    if (pill) pill.className = 'sse-live-pill live';
    addLiveEntry('🔌', 'Connected to Forge live stream');
  });
  es.addEventListener('task_start', e => {
    const d = JSON.parse(e.data);
    addLiveEntry('▶', `Started: ${d.title} ${d.gpuTemp ? `(GPU: ${d.gpuTemp}°C)` : ''}`);
    document.getElementById('live-event-text').textContent = `▶ ${d.title?.slice(0,40)}`;
    _activeAgents = {}; renderAgentBar();
  });
  es.addEventListener('agent', e => {
    const d = JSON.parse(e.data);
    const icons = {research:'🔍', architect:'🏗', coder:'🧑‍💻', refactor:'♻️', tester:'🧪', debugger:'🐛', reviewer:'👁'};
    const icon = icons[d.agent] || '🤖';
    const status = d.status === 'done' ? `✓ score:${d.score}` : 'running…';
    addLiveEntry(icon, `${d.agent}: ${status} — ${d.task?.slice(0,35)}`);
    document.getElementById('live-event-text').textContent = `${icon} ${d.agent} ${status}`;
    updateAgentStatus(d.agent, d.status, d.score);
  });
  es.addEventListener('pipeline_stage', e => {
    const d = JSON.parse(e.data);
    updateAgentStatus(d.role, d.status, d.score);
    const STAGE_PCT = { research:10, architect:20, coder:40, reviewer:55, tester:65, debugger:75, refactor:85, security:92, docs:97 };
    showProgress(`${d.role} running...`, STAGE_PCT[d.role] || 50, d.score);
    appendPipelineStageToChat(d);
  });
  es.addEventListener('file_written', e => {
    const d = JSON.parse(e.data);
    addLiveEntry('📄', `Wrote ${d.file} (score ${d.score}/10)`);
    refreshAll();
  });
  es.addEventListener('tests', e => {
    const d = JSON.parse(e.data);
    addLiveEntry(d.passed ? '✅' : '❌', `Tests ${d.passed ? 'PASSED' : 'FAILED'} — ${d.task?.slice(0,35)}`);
  });
  es.addEventListener('task_done', e => {
    const d = JSON.parse(e.data);
    addLiveEntry('🏁', `Done: ${d.title?.slice(0,40)} — score:${d.qualityScore}/10 tests:${d.testsPassed===true?'✅':d.testsPassed===false?'❌':'n/a'}`);
    refreshAll();
    toast(`✓ ${d.title?.slice(0,40)} — ${d.qualityScore}/10`, 'success');
    showProgress(`✓ Task complete`, 100, d.qualityScore);
    setTimeout(hideProgress, 3000);
    _activeAgents = {}; renderAgentBar();
  });
  es.addEventListener('log', e => {
    try {
      const d = JSON.parse(e.data);
      addLiveEntry('📝', d.msg || d.message || String(e.data));
    } catch { addLiveEntry('📝', String(e.data)); }
  });
  es.addEventListener('gpu_update', e => {
    try {
      const d = JSON.parse(e.data);
      if (d.temp != null) {
        const tempEl = document.getElementById('gpu-temp');
        if (tempEl) { tempEl.textContent = `${d.temp}°C`; tempEl.className = 'gval' + (d.temp >= 78 ? ' hot' : ''); }
      }
      if (d.memUsed != null) {
        const vramEl = document.getElementById('gpu-vram');
        if (vramEl) vramEl.textContent = `${d.memUsed}/${d.memTotal||4096}MB`;
        const pct = (d.memTotal > 0) ? Math.round(d.memUsed / d.memTotal * 100) : 0;
        const fill = document.getElementById('vram-fill');
        const label = document.getElementById('vram-label');
        if (fill) { fill.style.width = pct + '%'; fill.style.background = pct > 90 ? '#f44336' : pct > 75 ? '#ff9800' : '#7c6af5'; }
        if (label) label.textContent = `${d.memUsed}/${d.memTotal||4096}MB`;
      }
      if (d.power != null) {
        const pwrEl = document.getElementById('gpu-power');
        if (pwrEl) pwrEl.textContent = `${Math.round(d.power)}W`;
      }
    } catch {}
  });
  es.addEventListener('error', e => {
    try { const d = JSON.parse(e.data); addLiveEntry('💥', `Error: ${d.msg}`); } catch {}
  });

  es.addEventListener('auto_run_start', e => {
    const d = JSON.parse(e.data);
    addAutoBuildLog(`🚀 Auto-run started — ${d.total} tasks`);
    document.getElementById('ab-status').textContent = 'Running tasks...';
    refreshRunnerState(selectedProject?.id);
  });
  es.addEventListener('auto_run_task', e => {
    const d = JSON.parse(e.data);
    document.getElementById('ab-status').textContent = `Running: ${d.title}`;
    document.getElementById('ab-count').textContent = `${d.done} / ${d.total}`;
    if (d.total > 0) document.getElementById('ab-bar').style.width = `${Math.round(d.done/d.total*100)}%`;
    addAutoBuildLog(`⟳ Task: ${d.title}`);
  });
  es.addEventListener('auto_run_done', e => {
    const d = JSON.parse(e.data);
    const scoreColor = d.score >= 8 ? '#4caf50' : d.score >= 6 ? '#2196f3' : '#ff9800';
    addAutoBuildLog(`✅ Done: score <span style="color:${scoreColor};font-weight:700">${d.score}/10</span>`);
    document.getElementById('ab-count').textContent = `${d.done} / ${d.total}`;
    if (d.total > 0) document.getElementById('ab-bar').style.width = `${Math.round(d.done/d.total*100)}%`;
    refreshRunnerState(selectedProject?.id);
    refreshAll();
  });
  es.addEventListener('auto_run_fail', e => {
    const d = JSON.parse(e.data);
    addAutoBuildLog(`❌ Task failed (${d.consecutiveFails} consecutive fails): ${d.error||''}`);
    refreshRunnerState(selectedProject?.id);
  });
  es.addEventListener('auto_run_complete', e => {
    const d = JSON.parse(e.data);
    document.getElementById('ab-status').textContent = `Complete! ${d.done}/${d.total} done in ${d.elapsed}s`;
    document.getElementById('ab-bar').style.width = '100%';
    addAutoBuildLog(`🎉 Auto-build complete! ${d.done} tasks done, ${d.failed} failed, ${d.elapsed}s`);
    toast(`🎉 Auto-build complete! ${d.done}/${d.total} tasks done`, 'success');
    refreshRunnerState(selectedProject?.id);
    refreshAll();
  });
  es.addEventListener('auto_run_commit', e => {
    const d = JSON.parse(e.data);
    addAutoBuildLog(`📦 Git commit: "${d.title}" (score:${d.score}/10)`);
  });
  es.addEventListener('scaffold_complete', e => {
    const d = JSON.parse(e.data);
    addAutoBuildLog(`🏗 Scaffolded: ${(d.files||[]).join(', ')}`);
  });
  es.addEventListener('verify_result', e => {
    const d = JSON.parse(e.data);
    addAutoBuildLog(`▶ Output test: ${d.success ? '✅ PASS' : '❌ FAIL'} — ${d.command}`);
    if (d.output) addAutoBuildLog(d.output.slice(0,200));
  });
  es.addEventListener('idle_improve_start', e => {
    const d = JSON.parse(e.data);
    addAutoBuildLog(`🔄 Idle improvement: project avg score ${d.avgScore?.toFixed(1)}/10`);
  });

  es.onerror = () => {
    sseActive = false;
    document.getElementById('sse-dot').classList.add('inactive');
    document.getElementById('live-event-text').textContent = 'Live stream disconnected — retrying…';
    const pill = document.getElementById('sse-live-pill');
    if (pill) pill.className = 'sse-live-pill';
    es.close();
    _sseConnection = null;
    setTimeout(initSSE, 5000);
  };
}
function addLiveEntry(icon, text) {
  const log = document.getElementById('sse-log');
  if (!log) return;
  const t = new Date().toLocaleTimeString('en', {hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const entry = document.createElement('div');
  entry.className = 'sse-entry';
  entry.innerHTML = `<span class="sse-icon">${icon}</span><span class="sse-text">${text}</span><span class="sse-time">${t}</span>`;
  if (log.children[0]?.textContent?.includes('Waiting')) log.innerHTML = '';
  log.appendChild(entry);
  log.scrollTop = log.scrollHeight;
}
function clearLiveLog() {
  const log = document.getElementById('sse-log');
  if (log) log.innerHTML = '<div style="color:var(--text3);font-size:11px">Cleared — waiting for pipeline events…</div>';
}

// ── GPU Status Polling ─────────────────────────────────────────────────────
async function pollGPU() {
  try {
    const d = await api('GET', '/system/gpu');
    const tempEl = document.getElementById('gpu-temp');
    const vramEl = document.getElementById('gpu-vram');
    const pwrEl  = document.getElementById('gpu-power');
    if (tempEl) { tempEl.textContent = `${d.temp||0}°C`; tempEl.className = 'gval' + (d.temp >= 78 ? ' hot' : ''); }
    if (vramEl) vramEl.textContent = `${d.memUsed||0}/${d.memTotal||4096}MB`;
    if (pwrEl)  pwrEl.textContent  = `${Math.round(d.power||0)}W`;
  } catch {}
}

// ── Model Picker ───────────────────────────────────────────────────────────
async function loadModels() {
  try {
    const d = await api('GET', '/models');
    const sel = document.getElementById('model-picker');
    if (!sel) return;
    sel.innerHTML = d.models.map(m => {
      const active = m.name.startsWith(d.current) || d.current.startsWith(m.name.split(':')[0]);
      return `<option value="${m.name}" ${active?'selected':''}>${m.name} (${Math.round(m.sizeMB/1024*10)/10}GB)</option>`;
    }).join('');
  } catch { document.getElementById('model-picker').innerHTML = '<option value="phi3.5-forge:latest">phi3.5-forge</option>'; }
}
async function switchModel(modelName) {
  if (!modelName) return;
  if (!selectedProject) {
    toast('Select a project first to switch its model', 'error');
    // Reset picker back to current value
    loadModels();
    return;
  }
  await api('POST', `/project/${selectedProject.id}/set-model`, { model: modelName });
  toast(`Model switched to ${modelName}`, 'success');
}

// ── Utilities ──────────────────────────────────────────────────────────────
async function api(method, url, body) {
  const r = await fetch(API + url, {
    method, headers: {'Content-Type':'application/json'},
    body: body ? JSON.stringify(body) : undefined
  });
  return r.json();
}
function toast(msg, type='info') {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  document.getElementById('toasts').appendChild(el);
  setTimeout(() => el.remove(), 4000);
}
function scoreColor(s) {
  if (!s && s !== 0) return 'color:var(--text3)';
  if (s >= 8) return 'color:var(--green)';
  if (s >= 6) return 'color:var(--yellow)';
  return 'color:var(--red)';
}
function scoreClass(s) {
  if (!s && s !== 0) return '';
  if (s >= 8) return 'score-high';
  if (s >= 6) return 'score-mid';
  return 'score-low';
}
function badgeClass(status) {
  if (status === 'done') return 'badge-done';
  if (status === 'in_progress') return 'badge-running';
  if (status === 'pending') return 'badge-pending';
  return 'badge-failed';
}
function badgeLabel(status) {
  if (status === 'in_progress') return '⚡ running';
  return status;
}
function elapsed(ts) {
  if (!ts) return '';
  const diff = Date.now() - new Date(ts).getTime();
  if (diff < 60000) return `${Math.round(diff/1000)}s ago`;
  if (diff < 3600000) return `${Math.round(diff/60000)}m ago`;
  return `${Math.round(diff/3600000)}h ago`;
}

// ── Data loading ───────────────────────────────────────────────────────────
async function loadStats() {
  try {
    stats = await api('GET', '/stats');
    document.getElementById('h-done').textContent = stats.tasks?.done ?? '—';
    document.getElementById('h-pending').textContent = stats.tasks?.pending ?? '—';
    document.getElementById('h-score').textContent = stats.avgQualityScore !== 'N/A' ? stats.avgQualityScore + '/10' : '—';
    // Server status
    const pill = document.getElementById('server-status');
    pill.className = 'status-pill ok';
    pill.innerHTML = '<div class="dot"></div><span>Connected</span>';
  } catch {
    const pill = document.getElementById('server-status');
    pill.className = 'status-pill err';
    pill.innerHTML = '<div class="dot"></div><span>Offline</span>';
  }
}

async function loadProjects() {
  try {
    projects = await api('GET', '/projects');
    const el = document.getElementById('proj-list');
    if (!projects.length) { el.innerHTML = '<div class="empty" style="padding:20px;font-size:12px;text-align:center"><div class="empty-icon">🔨</div><div class="empty-text" style="margin-bottom:12px">No projects yet</div><button class="btn btn-primary" style="font-size:12px" onclick="openWizard()">+ Create First Project</button></div>'; return; }
    el.innerHTML = projects.map(p => {
      const pct = p.task_total > 0 ? Math.round((p.task_done/p.task_total)*100) : 0;
      const isActive = selectedProject?.id === p.id;
      const projectPath = `/home/mrnova420/forge/projects/${p.id}`;
      return `<div class="proj-item${isActive?' active':''}" onclick="selectProject('${p.id}')">
        <div class="proj-name">${p.name}</div>
        <div class="proj-meta">${p.task_done||0}/${p.task_total||0} tasks · ${p.stack||'node'}</div>
        <div style="font-size:10px;color:#444;margin-top:4px;display:flex;align-items:center;gap:6px;">
          <span style="font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;" title="${projectPath}">${projectPath}</span>
          <button onclick="navigator.clipboard.writeText('${projectPath}').then(()=>showToast('Path copied!'))" style="background:none;border:none;color:#555;cursor:pointer;font-size:10px;padding:0;" title="Copy path">📋</button>
          <button onclick="openInWorkspace('${p.id}')" style="background:none;border:none;color:#555;cursor:pointer;font-size:10px;padding:0;" title="Set as active workspace">📁</button>
        </div>
        <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
        <div style="display:flex;gap:4px;margin-top:8px" onclick="event.stopPropagation()">
          <button class="task-action-btn" style="font-size:10px;flex:1" onclick="quickProjectAction('${p.id}','run')" title="Run full dev cycle">▶ Run</button>
          <button class="task-action-btn" style="font-size:10px;flex:1" onclick="quickProjectAction('${p.id}','health')" title="Check project health">🏥</button>
          <button class="task-action-btn" style="font-size:10px;flex:1" onclick="quickProjectAction('${p.id}','backup')" title="Backup project">📦</button>
        </div>
      </div>`;
    }).join('');
  } catch(e) { console.error(e); }
  if (selectedProject) refreshRunnerState(selectedProject.id);
}

async function loadTasks() {
  try {
    tasks = await api('GET', '/tasks/recent?limit=50');
  } catch(e) { console.error(e); }
}

async function loadRunnerStatus() {
  try {
    const r = await api('GET', '/runner/status');
    const el = document.getElementById('runner-header');
    if (r.running) {
      el.className = 'runner-indicator on';
      el.innerHTML = '<div class="dot"></div><span>Runner active</span>';
    } else {
      el.className = 'runner-indicator off';
      el.innerHTML = '<div class="dot"></div><span>Runner idle</span>';
    }
  } catch {}
}

let _runnerStateInterval = null;
let _lastAutoRunStatus = null;

async function refreshRunnerState(projectId) {
  if (!projectId) return;
  try {
    const s = await api('GET', `/project/${projectId}/auto-run/status`);
    _lastAutoRunStatus = s;
    const el = document.getElementById('runner-header');
    if (!el) return;
    if (s.running) {
      el.className = 'runner-indicator on';
      el.innerHTML = `<div class="dot"></div><span>⚡ Running — ${s.inProgress || 0} active, ${s.pending || 0} pending</span>`;
    } else {
      el.className = 'runner-indicator off';
      el.innerHTML = `<div class="dot"></div><span>Runner idle — ${s.done || 0} done, ${s.pending || 0} pending</span>`;
    }
  } catch {}
}

async function refreshAll() {
  await Promise.all([loadStats(), loadProjects(), loadTasks(), loadRunnerStatus()]);
  renderView();
}

// ── Views ──────────────────────────────────────────────────────────────────
function showView(view) {
  currentView = view;
  ['overview','tasks','quality'].forEach(v => {
    document.getElementById('nav-'+v)?.classList.toggle('active', v === view);
  });
  renderView();
}

function renderView() {
  const ca = document.getElementById('content-area');
  if (currentView === 'overview') ca.innerHTML = renderOverview();
  else if (currentView === 'tasks') ca.innerHTML = renderTasksView();
  else if (currentView === 'quality') ca.innerHTML = renderQualityView();
  else if (currentView === 'project' && selectedProject) ca.innerHTML = renderProjectView();
}

function renderOverview() {
  const t = stats.tasks || {};
  const running = t.in_progress || 0;
  return `
    <div id="build-hero" style="
      background: linear-gradient(135deg, #1e1e2e 0%, #181825 100%);
