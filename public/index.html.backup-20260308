<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🔨 The Forge — AI Dev Team</title>
<style>
  :root {
    --bg: #0a0a14; --bg2: #0d0d1a; --bg3: #111122;
    --border: #1e1e35; --border2: #2a2a45;
    --accent: #7c6af5; --accent2: #4a3fa0;
    --green: #4caf50; --red: #f44336; --yellow: #ff9800; --blue: #3498db;
    --text: #e8e8f0; --text2: #9090a8; --text3: #505068;
    --radius: 10px; --font: 'Segoe UI', system-ui, sans-serif;
    /* Enhanced dark mode palette */
    --bg-primary: #0a0a14;
    --bg-secondary: #0d0d1a;
    --bg-card: #111122;
    --bg-elevated: #16162a;
    --border-bright: #2a2a45;
    --text-primary: #e8e8f0;
    --text-secondary: #9090a8;
    --text-muted: #505068;
    --accent-dim: #4a3fa0;
    --success: #4caf50;
    --warning: #ff9800;
    --error: #f44336;
    --code-bg: #080810;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); min-height: 100vh; }

  /* ── Layout ── */
  .app { display: grid; grid-template-rows: 56px auto auto 1fr; height: 100vh; overflow: hidden; }
  .main { display: grid; grid-template-columns: 260px 1fr 340px; height: 100%; overflow: hidden; }

  /* ── Header ── */
  header {
    background: var(--bg2); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; padding: 0 20px; gap: 16px;
    position: sticky; top: 0; z-index: 100;
  }
  .logo { font-size: 20px; font-weight: 700; color: var(--accent); letter-spacing: -0.5px; }
  .logo span { color: var(--text2); font-weight: 400; }
  .status-pill {
    display: flex; align-items: center; gap: 6px; padding: 4px 12px;
    border-radius: 20px; font-size: 12px; font-weight: 600; border: 1px solid;
  }
  .status-pill.ok { border-color: var(--green); color: var(--green); background: #2ecc7115; }
  .status-pill.err { border-color: var(--red); color: var(--red); background: #e74c3c15; }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .header-stats { display: flex; gap: 20px; margin-left: auto; }
  .hstat { text-align: right; }
  .hstat-val { font-size: 18px; font-weight: 700; color: var(--accent); }
  .hstat-lbl { font-size: 11px; color: var(--text3); }
  .btn {
    padding: 6px 14px; border-radius: 6px; border: none; cursor: pointer;
    font-size: 13px; font-weight: 600; transition: all 0.15s;
  }
  .btn-primary { background: var(--accent); color: white; }
  .btn-primary:hover { background: var(--accent2); }
  .btn-ghost { background: transparent; color: var(--text2); border: 1px solid var(--border2); }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
  .btn-danger { background: var(--red); color: white; }
  .btn-success { background: var(--green); color: #111; }

  /* ── Sidebar ── */
  .sidebar {
    background: var(--bg2); border-right: 1px solid var(--border);
    overflow-y: auto; padding: 16px 12px; display: flex; flex-direction: column; gap: 6px;
  }
  .sidebar-section { font-size: 10px; font-weight: 700; color: var(--text3); letter-spacing: 1px; text-transform: uppercase; padding: 10px 8px 4px; }
  .proj-item {
    padding: 10px 12px; border-radius: 8px; cursor: pointer;
    border: 1px solid transparent; transition: all 0.15s;
  }
  .proj-item:hover { background: var(--bg3); border-color: var(--border); }
  .proj-item.active { background: var(--bg3); border-color: var(--accent); }
  .proj-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .proj-meta { font-size: 11px; color: var(--text3); margin-top: 2px; }
  .progress-bar { height: 3px; background: var(--bg3); border-radius: 2px; margin-top: 6px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.5s; }
  .nav-btn {
    display: flex; align-items: center; gap: 8px; padding: 9px 12px;
    border-radius: 8px; cursor: pointer; font-size: 13px;
    color: var(--text2); transition: all 0.15s; border: none; background: none; width: 100%; text-align: left;
  }
  .nav-btn:hover { background: var(--bg3); color: var(--text); }
  .nav-btn.active { background: var(--bg3); color: var(--accent); }

  /* ── Main Content ── */
  .content { overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 20px; }

  /* ── Cards ── */
  .card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; }
  .card-title { font-size: 13px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .stat-box { background: var(--bg3); border-radius: 8px; padding: 14px; text-align: center; border: 1px solid var(--border); }
  .stat-num { font-size: 28px; font-weight: 800; }
  .stat-lbl { font-size: 11px; color: var(--text3); margin-top: 4px; }
  .stat-num.green { color: var(--green); }
  .stat-num.yellow { color: var(--yellow); }
  .stat-num.blue { color: var(--blue); }
  .stat-num.accent { color: var(--accent); }

  /* ── Task list ── */
  .task-list { display: flex; flex-direction: column; gap: 8px; }
  .task-row {
    display: flex; align-items: center; gap: 12px; padding: 10px 14px;
    background: var(--bg3); border-radius: 8px; border: 1px solid var(--border);
    transition: border-color 0.15s; cursor: pointer;
  }
  .task-row:hover { border-color: var(--border2); }
  .task-row.running { border-color: var(--yellow); animation: glow 2s infinite; }
  @keyframes glow { 0%,100%{box-shadow:0 0 0 0 transparent} 50%{box-shadow:0 0 10px 2px #f39c1220} }
  .task-badge {
    font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px;
    white-space: nowrap; flex-shrink: 0;
  }
  .badge-done { background: #2ecc7120; color: var(--green); border: 1px solid #2ecc7140; }
  .badge-pending { background: #9090b015; color: var(--text3); border: 1px solid var(--border); }
  .badge-running { background: #f39c1220; color: var(--yellow); border: 1px solid #f39c1240; }
  .badge-failed { background: #e74c3c20; color: var(--red); border: 1px solid #e74c3c40; }
  .task-title { flex: 1; font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .task-score { font-size: 13px; font-weight: 700; min-width: 42px; text-align: right; }
  .score-high { color: var(--green); }
  .score-mid { color: var(--yellow); }
  .score-low { color: var(--red); }
  .task-epic { font-size: 11px; color: var(--text3); flex-shrink: 0; max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ── Runner panel ── */
  .runner-panel { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .runner-indicator {
    display: flex; align-items: center; gap: 8px; padding: 8px 16px;
    border-radius: 20px; font-size: 13px; font-weight: 600; border: 1px solid;
  }
  .runner-indicator.on { border-color: var(--green); color: var(--green); background: #2ecc7112; }
  .runner-indicator.off { border-color: var(--border2); color: var(--text3); }

  /* ── Right panel ── */
  .right-panel {
    background: var(--bg2); border-left: 1px solid var(--border);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .panel-tabs { display: flex; border-bottom: 1px solid var(--border); }
  .panel-tab {
    flex: 1; padding: 12px; font-size: 12px; font-weight: 600; cursor: pointer;
    color: var(--text3); border-bottom: 2px solid transparent; transition: all 0.15s;
    text-align: center; background: none; border-top: none; border-left: none; border-right: none;
  }
  .panel-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .panel-tab:hover:not(.active) { color: var(--text2); }
  .panel-body { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 12px; }

  /* ── Agent chat ── */
  .chat-msg { display: flex; gap: 12px; padding: 8px 0; align-items: flex-start; }
  .chat-msg.user { display: block; background: var(--accent); color: white; align-self: flex-end; max-width: 90%; border-radius: 8px 8px 2px 8px; padding: 10px 12px; font-size: 13px; line-height: 1.5; }
  .chat-msg.agent { display: block; background: var(--bg3); border: 1px solid var(--border); max-width: 95%; border-radius: 8px 8px 8px 2px; padding: 10px 12px; font-size: 13px; line-height: 1.5; }
  .chat-msg.system { display: block; background: transparent; color: var(--text3); font-size: 11px; text-align: center; border: none; padding: 4px 0; }
  .user-msg .msg-content { background: var(--accent); color: white; border-radius: 12px 12px 4px 12px; padding: 10px 14px; font-size: 13px; line-height: 1.6; max-width: 80%; }
  .assist-msg .msg-content { background: transparent; padding: 6px 0; font-size: 13px; line-height: 1.8; max-width: 90%; white-space: pre-wrap; }
  .msg-avatar { font-size: 18px; width: 28px; text-align: center; flex-shrink: 0; padding-top: 4px; }
  .typing-indicator { color: var(--accent); animation: pulse 1s infinite; letter-spacing: 3px; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .chat-input-row { padding: 10px 14px; border-top: 1px solid var(--border); display: flex; gap: 8px; background: var(--bg2); align-items: flex-end; }
  .chat-input {
    flex: 1; background: var(--bg3); border: 1px solid var(--border); border-radius: 12px;
    color: var(--text); padding: 10px 14px; font-size: 13px; resize: none; min-height: 44px;
    max-height: 150px; overflow-y: auto; line-height: 1.5; font-family: var(--font); outline: none;
    transition: border-color 0.2s;
  }
  .chat-input:focus { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(99,102,241,0.2); }
  .chat-suggestions { display: flex; gap: 6px; flex-wrap: wrap; padding: 6px 14px 2px; }
  .suggestion-chip { background: var(--bg3); border: 1px solid var(--border); border-radius: 20px; padding: 4px 12px; font-size: 11px; color: var(--text3); cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .suggestion-chip:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .agent-select {
    background: var(--bg3); border: 1px solid var(--border); color: var(--text);
    border-radius: 6px; padding: 6px 10px; font-size: 12px; outline: none;
  }
  .thinking { color: var(--text3); font-size: 12px; animation: ellipsis 1.5s infinite; }
  @keyframes ellipsis { 0%{content:'.'} 33%{content:'..'} 66%{content:'...'} }

  /* ── Log viewer ── */
  .log-box {
    background: var(--code-bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 12px; font-family: 'Courier New', monospace; font-size: 11px;
    line-height: 1.6; color: #a0c0a0; overflow-y: auto; max-height: 100%;
    white-space: pre-wrap; word-break: break-all;
  }
  .log-box .log-err { color: var(--red); }
  .log-box .log-ok { color: var(--green); }
  .log-box .log-warn { color: var(--yellow); }

  /* ── Code viewer ── */
  .code-box {
    background: var(--code-bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 12px; font-family: 'Courier New', monospace; font-size: 12px;
    line-height: 1.6; overflow: auto; max-height: 400px; white-space: pre; color: #c0d0e0;
  }
  .file-list { display: flex; flex-direction: column; gap: 4px; }
  .file-item {
    padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 12px;
    font-family: monospace; color: var(--text2); transition: all 0.12s;
    border: 1px solid transparent;
  }
  .file-item:hover { background: var(--bg3); border-color: var(--border); color: var(--text); }
  .file-item.active { background: var(--bg3); border-color: var(--accent); color: var(--accent); }

  /* ── Modal ── */
  .modal-overlay {
    position: fixed; inset: 0; background: #0008; z-index: 1000;
    display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--bg2); border: 1px solid var(--border2); border-radius: 14px;
    padding: 28px; width: 480px; max-width: 95vw; transform: scale(0.95); transition: transform 0.2s;
  }
  .modal-overlay.open .modal { transform: scale(1); }
  .modal-title { font-size: 18px; font-weight: 700; margin-bottom: 20px; }
  .form-group { margin-bottom: 14px; }
  .form-label { font-size: 12px; font-weight: 600; color: var(--text2); display: block; margin-bottom: 6px; }
  .form-input, .form-textarea, .form-select {
    width: 100%; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); padding: 9px 12px; font-size: 14px; outline: none; font-family: var(--font);
  }
  .form-textarea { resize: vertical; min-height: 80px; }
  .form-input:focus, .form-textarea:focus, .form-select:focus { border-color: var(--accent); }
  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }

  /* ── Quality chart ── */
  .quality-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .quality-label { font-size: 12px; width: 80px; color: var(--text2); }
  .quality-track { flex: 1; height: 8px; background: var(--bg3); border-radius: 4px; overflow: hidden; }
  .quality-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--accent2), var(--accent)); transition: width 0.8s; }
  .quality-val { font-size: 12px; font-weight: 700; width: 36px; text-align: right; }

  /* ── Empty state ── */
  .empty { text-align: center; padding: 40px; color: var(--text3); }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-text { font-size: 14px; }

  /* ── Custom agent dropdown ── */
  .agent-dropdown { position: relative; width: 100%; margin-bottom: 8px; }
  .agent-dropdown-btn {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); padding: 7px 12px; font-size: 12px; cursor: pointer;
    transition: border-color 0.15s;
  }
  .agent-dropdown-btn:hover, .agent-dropdown-btn.open { border-color: var(--accent); }
  .agent-dropdown-menu {
    position: absolute; bottom: calc(100% + 4px); left: 0; right: 0;
    background: var(--bg2); border: 1px solid var(--border2); border-radius: 8px;
    overflow: hidden; z-index: 200; display: none; box-shadow: 0 -8px 24px #0008;
  }
  .agent-dropdown-menu.open { display: block; }
  .agent-opt {
    padding: 9px 14px; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 8px;
    transition: background 0.1s; border-bottom: 1px solid var(--border);
  }
  .agent-opt:last-child { border-bottom: none; }
  .agent-opt:hover { background: var(--bg3); }
  .agent-opt.selected { color: var(--accent); background: #7c6af710; }
  .agent-opt-desc { font-size: 10px; color: var(--text3); margin-left: auto; }

  /* ── Task actions ── */
  .task-actions { display: flex; gap: 4px; flex-shrink: 0; opacity: 0; transition: opacity 0.15s; }
  .task-row:hover .task-actions { opacity: 1; }
  .task-action-btn {
    padding: 2px 7px; border-radius: 4px; font-size: 10px; font-weight: 600;
    border: 1px solid var(--border); background: transparent; cursor: pointer; color: var(--text3);
    transition: all 0.1s;
  }
  .task-action-btn:hover { border-color: var(--accent); color: var(--accent); }
  .task-action-btn.danger:hover { border-color: var(--red); color: var(--red); }

  /* ── Time badges ── */
  .time-badge { font-size: 10px; color: var(--text3); flex-shrink: 0; }

  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

  /* ── Toasts ── */
  .toast-container { position: fixed; bottom: 20px; right: 20px; display: flex; flex-direction: column; gap: 8px; z-index: 9999; }
  .toast {
    padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
    background: var(--bg2); border: 1px solid var(--border2); max-width: 320px;
    animation: slideIn 0.3s ease; box-shadow: 0 4px 20px #0006;
  }
  .toast.success { border-color: var(--green); color: var(--green); }
  .toast.error { border-color: var(--red); color: var(--red); }
  .toast.info { border-color: var(--blue); color: var(--blue); }
  @keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }

  /* ── Spinner ── */
  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid var(--border2); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.7s linear infinite; }
  @keyframes spin { to{transform:rotate(360deg)} }

  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .section-title { font-size: 16px; font-weight: 700; }
  .badge-count { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; font-size: 11px; padding: 2px 8px; color: var(--text3); }
  .gpu-bar { display:flex;align-items:center;gap:8px;padding:5px 16px;background:var(--bg3);border-bottom:1px solid var(--border);font-size:11px;color:var(--text3); }
  .gpu-bar .gval { color:var(--text);font-weight:600; }
  .gpu-bar .hot { color:#ef4444; }
  .live-dot { width:7px;height:7px;border-radius:50%;background:#22c55e;animation:pulse 1.5s ease-in-out infinite; }
  .live-dot.inactive { background:var(--text3);animation:none; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.4} }
  .sse-log { font-size:11px;font-family:monospace;line-height:1.7;max-height:220px;overflow-y:auto;padding:8px 12px; }
  .sse-entry { padding:2px 0;border-bottom:1px solid var(--border);display:flex;gap:8px; }
  .sse-entry .sse-icon { width:20px;flex-shrink:0;text-align:center; }
  .sse-entry .sse-text { color:var(--text2);flex:1; }
  .sse-entry .sse-time { color:var(--text3);font-size:10px;flex-shrink:0; }
  .model-select { background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:11px;padding:3px 8px;cursor:pointer; }

  /* ── Wizard ── */
  #wizard-overlay { opacity:1;pointer-events:all; }
  .wizard-step { display:none }
  .wizard-step.active { display:block }
  .wizard-steps-indicator { display:flex;gap:8px;margin-bottom:18px }
  .wizard-dot { width:8px;height:8px;border-radius:50%;background:var(--border) }
  .wizard-dot.active { background:var(--accent) }
  .wizard-dot.done { background:var(--green) }
  .stack-options { display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:12px 0 }
  .stack-opt { padding:10px;background:var(--bg3);border:2px solid var(--border);border-radius:8px;text-align:center;cursor:pointer;font-size:12px;transition:border-color 0.2s }
  .stack-opt:hover,.stack-opt.selected { border-color:var(--accent);color:var(--accent) }
  .chart-canvas { width:100%;height:80px;border-radius:6px;background:var(--bg3) }
  .sse-live-pill { display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;border:1px solid var(--border2);color:var(--text3);cursor:default }
  .sse-live-pill.live { border-color:var(--green);color:var(--green) }
  .sse-live-pill .sse-live-dot { width:6px;height:6px;border-radius:50%;background:currentColor }
  /* ── Task Detail Modal ── */
  .pipeline-stage { background:#0d0d1a; border:1px solid #2a2a3e; border-radius:4px; padding:10px; margin:8px 0; }
  .pipeline-stage h4 { color:#7c6af5; margin:0 0 6px 0; font-size:12px; text-transform:uppercase; }
  .pipeline-stage pre { color:#c0c0c0; white-space:pre-wrap; word-break:break-word; font-size:11px; margin:0; max-height:200px; overflow-y:auto; }
  .score-badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:bold; }
  .score-high { background:#1a3a1a; color:#4caf50; }
  .score-med { background:#3a2a00; color:#ff9800; }
  .score-low { background:#3a1a1a; color:#f44336; }
  /* ── Syntax Highlighting ── */
  .code-keyword { color: #c678dd; }
  .code-string { color: #98c379; }
  .code-comment { color: #5c6370; font-style: italic; }
  .code-number { color: #d19a66; }
  .code-function { color: #61afef; }
  .check-item { padding: 8px 0; color: #9090a8; font-size: 13px; border-bottom: 1px solid #1e1e35; }
  .check-item.ok { color: #4caf50; }
  .check-item.fail { color: #f44336; }

  /* Grade badge colors */
  .grade-S { background: #ffd700; color: #000; font-weight: 800; }
  .grade-A { background: #00c851; color: #fff; font-weight: 800; }
  .grade-B { background: #007bff; color: #fff; font-weight: 800; }
  .grade-C { background: #ff8800; color: #fff; font-weight: 800; }
  .grade-D { background: #ff4444; color: #fff; font-weight: 800; }
