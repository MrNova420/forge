function showWizardStep(n) {
  [1,2,3].forEach(i => {
    document.getElementById(`wstep-${i}`).classList.toggle('active', i===n);
    const dot = document.getElementById(`wdot-${i}`);
    if (dot) { dot.className = 'wizard-dot' + (i < n ? ' done' : i===n ? ' active' : ''); }
  });
