          ${pkg.url ? `<a href="${pkg.url}" target="_blank" style="color:var(--accent);font-size:10px;flex-shrink:0">npm ↗</a>` : ''}
        </div>`;
      });
    }

    // StackOverflow results
    const soRes = r.stackoverflow;
    if (soRes?.questions?.length) {
      html += `<div style="font-size:11px;font-weight:700;color:var(--text3);margin:12px 0 6px;text-transform:uppercase;letter-spacing:1px">💬 StackOverflow</div>`;
      soRes.questions.forEach(q => {
        html += `<div style="margin-bottom:8px;padding:8px 12px;background:var(--bg3);border-radius:8px">
          <div style="display:flex;align-items:start;gap:8px">
            <div style="flex:1">
              <a href="${q.url}" target="_blank" style="color:var(--accent);font-size:12px;text-decoration:none;font-weight:600">${q.title}</a>
              <div style="font-size:10px;color:var(--text3);margin-top:2px">▲${q.score} votes · ${q.answers} answers${q.answered ? ' · ✅ answered' : ''} · ${q.tags}</div>
            </div>
          </div>
          ${q.body ? `<div style="font-size:11px;color:var(--text2);margin-top:4px">${q.body}</div>` : ''}
        </div>`;
      });
    }

    area.innerHTML = html || '<div style="color:var(--text3);padding:8px">No results found. Try a different query.</div>';
  } catch(e) { area.innerHTML = `<div style="color:var(--red);padding:8px">Search failed: ${e.message}</div>`; }
