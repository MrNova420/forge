    <div class="wizard-step" id="wstep-2">
      <div style="font-size:11px;color:var(--text3);margin-bottom:12px">Step 2 of 3 — Tech Stack & Model</div>
      <div style="font-size:12px;margin-bottom:6px;color:var(--text2)">Choose stack:</div>
      <div class="stack-options" style="grid-template-columns:repeat(4,1fr)">
        <div class="stack-opt selected" data-stack="node" onclick="selectStack(this)">🟢 Node.js</div>
        <div class="stack-opt" data-stack="react" onclick="selectStack(this)">⚛️ React</div>
        <div class="stack-opt" data-stack="python" onclick="selectStack(this)">🐍 Python</div>
        <div class="stack-opt" data-stack="cli" onclick="selectStack(this)">⌨️ CLI</div>
        <div class="stack-opt" data-stack="rust" onclick="selectStack(this)">🦀 Rust</div>
        <div class="stack-opt" data-stack="go" onclick="selectStack(this)">🐹 Go</div>
        <div class="stack-opt" data-stack="web" onclick="selectStack(this)">🌐 Web</div>
        <div class="stack-opt" data-stack="api" onclick="selectStack(this)">🔌 API</div>
      </div>
      <div style="font-size:12px;margin:10px 0 6px;color:var(--text2)">AI Model:</div>
      <select id="wizard-model" onchange="updateModelVramHint(this.value)" style="width:100%;padding:8px;background:#0d0d1a;color:#e0e0e0;border:1px solid #333;border-radius:4px;margin-top:6px;">
        <option value="phi3.5-forge">phi3.5-forge (2.2GB - Recommended ✓)</option>
        <option value="phi3.5:latest">phi3.5:latest (2.2GB)</option>
        <option value="qwen2.5-coder:1.5b">qwen2.5-coder:1.5b (1.0GB - 16K ctx)</option>
        <option value="deepseek-coder:1.3b">deepseek-coder:1.3b (0.8GB - 24K ctx)</option>
      </select>
      <div id="vram-hint" style="margin-top:6px;font-size:11px;"></div>
