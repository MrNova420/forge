// ── Auto-Build ────────────────────────────────────────────────────────────────
let _autoBuildProject = null;
let _runnerPollInterval = null;
let _taskRefreshInterval = null;

async function startAutoBuild(projectId) {
  if (!projectId && selectedProject) projectId = selectedProject.id;
  if (!projectId) return toast('Select a project first', 'error');
  _autoBuildProject = projectId;

  const panel = document.getElementById('auto-build-panel');
  if (panel) { panel.style.display = 'block'; }
  switchTab('chat');
  document.getElementById('ab-status').textContent = 'Starting auto-build...';
  document.getElementById('ab-count').textContent = '0 / ?';
  document.getElementById('ab-bar').style.width = '0%';
  document.getElementById('auto-build-log').innerHTML = '';
  addBuildLog('🚀 Starting auto-build...');

  try {
    const r = await api('POST', `/project/${projectId}/auto-run`, { maxFails: 3 });
    addBuildLog(`✅ Auto-run started — ${r.pending || r.total || '?'} tasks queued`);
    document.getElementById('ab-count').textContent = `0 / ${r.pending || r.total || '?'}`;
    toast(`⚡ Auto-Build started! ${r.pending || r.total || '?'} tasks to complete.`, 'success');
    await refreshRunnerState(projectId);

    // Poll runner state every 5s
    if (_runnerPollInterval) clearInterval(_runnerPollInterval);
    _runnerPollInterval = setInterval(async () => {
      await refreshRunnerState(projectId);
      const s = await api('GET', `/project/${projectId}/auto-run/status`).catch(() => ({}));
      if (!s.running && s.pending === 0) {
        clearInterval(_runnerPollInterval);
        _runnerPollInterval = null;
        if (_taskRefreshInterval) { clearInterval(_taskRefreshInterval); _taskRefreshInterval = null; }
        addBuildLog(`🏁 Build complete — ${s.done || 0} tasks done`);
        await loadProjects();
      }
    }, 5000);

    // Auto-refresh task list every 15s while build is running
    if (_taskRefreshInterval) clearInterval(_taskRefreshInterval);
    _taskRefreshInterval = setInterval(async () => {
      if (currentView === 'project' && selectedProject && _autoBuildProject === selectedProject.id) {
        const detail = await api('GET', `/projects/${selectedProject.id}`).catch(() => null);
        if (detail && detail.tasks) {
          selectedProject = { ...selectedProject, tasks: detail.tasks, epics: detail.epics };
          // Also refresh the global tasks array for this project
          const others = tasks.filter(t => t.project_id !== selectedProject.id && t.project_name !== selectedProject.name);
          tasks = [...others, ...(detail.tasks || [])];
          const taskEl = document.getElementById('task-list-container');
          if (taskEl) taskEl.innerHTML = renderTaskList(detail.tasks);
        }
      }
    }, 15000);
  } catch(e) {
    addBuildLog('❌ Error: ' + e.message);
    toast('Auto-build failed to start: ' + e.message, 'error');
  }
}

async function stopAutoBuild(projectId) {
  const pid = projectId || _autoBuildProject || selectedProject?.id;
  if (!pid) return toast('Nothing running', 'info');
  try {
    await api('POST', `/project/${pid}/auto-run/stop`);
    if (_runnerPollInterval) { clearInterval(_runnerPollInterval); _runnerPollInterval = null; }
    if (_taskRefreshInterval) { clearInterval(_taskRefreshInterval); _taskRefreshInterval = null; }
    toast('⏹ Auto-build stopped', 'info');
    addBuildLog('⏹ Stopped by user');
    await refreshRunnerState(pid);
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

function addBuildLog(msg) {
  const el = document.getElementById('auto-build-log');
  if (!el) return;
  const entry = document.createElement('div');
  entry.className = 'sse-entry';
  entry.innerHTML = `<span class="sse-icon">▶</span><span class="sse-text">${msg}</span><span class="sse-time">${new Date().toLocaleTimeString()}</span>`;
  el.appendChild(entry);
  el.scrollTop = el.scrollHeight;
}

function addAutoBuildLog(msg) {
  const log = document.getElementById('auto-build-log');
  if (!log) return;
  const time = new Date().toLocaleTimeString();
  const div = document.createElement('div');
  div.innerHTML = `<span style="color:var(--text3)">[${time}]</span> ${msg}`;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
}

async function scaffoldCode(projectId) {
  if (!projectId) return toast('No project selected', 'error');
  toast('🏗 Scaffolding project files...', 'info');
  try {
    const r = await api('POST', `/project/${projectId}/scaffold-code`);
    toast(`✅ Scaffolded ${r.written?.length || 0} files: ${(r.written||[]).join(', ')}`, 'success');
    await refreshAll();
  } catch(e) { toast('Scaffold failed: ' + e.message, 'error'); }
}

async function verifyOutput(projectId) {
  if (!projectId) return toast('No project selected', 'error');
  toast('▶ Running project output...', 'info');
  try {
    const r = await api('POST', `/project/${projectId}/verify-output`);
    if (r.success) {
      toast(`✅ Project runs! Output: ${(r.output||'').slice(0,100)}`, 'success');
    } else {
      toast(`❌ Run failed (exit ${r.exitCode}): ${(r.output||'').slice(0,150)}`, 'error');
    }
    addAutoBuildLog(`▶ Run ${r.success?'✅ SUCCESS':'❌ FAILED'}: ${r.command} → exit ${r.exitCode}`);
    if (r.output) addAutoBuildLog(r.output.slice(0, 200));
  } catch(e) { toast('Verify failed: ' + e.message, 'error'); }
}

