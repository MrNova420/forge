// ── Actions ────────────────────────────────────────────────────────────────
async function selectProject(id) {
  try {
    // Stop auto-run for previous project if switching
    if (selectedProject && selectedProject.id !== id && _autoBuildProject === selectedProject.id) {
      try { await api('POST', `/project/${selectedProject.id}/auto-run/stop`); } catch {}
      if (_runnerPollInterval) { clearInterval(_runnerPollInterval); _runnerPollInterval = null; }
    }
    const detail = await api('GET', `/projects/${id}`);
    selectedProject = { ...projects.find(p=>p.id===id), ...detail };
    currentView = 'project';
    document.querySelectorAll('.proj-item').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.proj-item').forEach(el => {
      if (el.onclick?.toString().includes(id)) el.classList.add('active');
    });
    renderView();
    browseFiles(id);
    loadChatHistory(id);
    renderChatSuggestions(id);
    await refreshRunnerState(id);
    if (_runnerStateInterval) clearInterval(_runnerStateInterval);
    _runnerStateInterval = setInterval(() => refreshRunnerState(selectedProject?.id), 8000);
  } catch(e) { toast('Failed to load project', 'error'); }
}

async function startRunner() {
  const btn = event.target;
  btn.disabled = true; btn.textContent = '...';
  try {
    const r = await api('POST', '/runner/start');
    if (r.started) toast('Auto-runner started!', 'success');
    else toast(r.message || 'Already running', 'info');
    await loadRunnerStatus(); refreshAll();
  } catch { toast('Failed to start runner', 'error'); }
  btn.disabled = false; btn.textContent = '▶ Start Runner';
}

async function stopRunner() {
  try {
    const r = await api('POST', '/runner/stop');
    if (r.stopped) toast('Runner stopped', 'info');
    else toast('Runner not running', 'info');
    await loadRunnerStatus(); refreshAll();
  } catch { toast('Failed to stop runner', 'error'); }
}

async function stepTask() {
  const btn = event.target;
  btn.disabled = true; btn.textContent = '⏳ Running...';
  const toastMsg = selectedProject
    ? `Running next task for "${selectedProject.name}" — this takes 5-10 min...`
    : 'Running next task — this takes 5-10 min...';
  toast(toastMsg, 'info');
  try {
    const payload = selectedProject ? { projectId: selectedProject.id } : {};
    const r = await api('POST', '/task/run-next', payload);
    if (r.message) toast(r.message, 'info');
    else if (r.taskId) {
      toast(`✅ Task done! Score: ${r.qualityScore}/10`, 'success');
      await refreshAll();
    } else if (r.error) toast('Error: ' + r.error, 'error');
  } catch { toast('Task failed', 'error'); }
  btn.disabled = false; btn.textContent = '⚡ Run One Task';
}

async function runImprove() {
  toast('Running self-improvement cycle...', 'info');
  try {
    const r = await api('POST', '/improve');
    toast('Self-improvement complete!', 'success');
    console.log('Improve result:', r);
  } catch { toast('Improve failed', 'error'); }
}

async function generateScripts(projectId) {
  const id = projectId || selectedProject?.id;
  if (!id) return toast('Select a project first', 'error');
  toast('Generating README, package.json & run script...', 'info');
  try {
    const r = await api('POST', `/project/${id}/generate-scripts`);
    toast(`Generated: ${(r.written||[]).join(', ')}`, 'success');
    browseFiles(id);
  } catch(e) { toast('Script generation failed: ' + e.message, 'error'); }
}

async function browseFiles(projectId) {
  switchTab('files');
  currentBrowseProject = projectId;
  const panel = document.getElementById('files-panel');
  panel.innerHTML = '<div style="padding:12px"><div class="spinner"></div></div>';
  try {
    const r = await api('GET', `/projects/${projectId}/files`);
    if (!r.files?.length) {
      panel.innerHTML = '<div class="chat-msg system" style="margin:12px">No files generated yet — run some tasks first.</div>';
      return;
    }
    const grouped = {};
    r.files.forEach(f => {
      const dir = f.path.includes('/') ? f.path.split('/')[0] : 'root';
      if (!grouped[dir]) grouped[dir] = [];
      grouped[dir].push(f);
    });
    let html = '<div style="padding:10px">';
    for (const [dir, files] of Object.entries(grouped)) {
      html += `<div style="font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;padding:8px 4px 4px">${dir}/</div>`;
      html += '<div class="file-list">';
      files.forEach(f => {
        const name = f.path.split('/').pop();
        const size = f.size < 1024 ? f.size + 'B' : Math.round(f.size/1024) + 'KB';
        // Use new /project/:id/file API for viewing with project context
        html += `<div class="file-item" onclick="viewFileByProject('${projectId}','${f.path}')" title="${f.path}">
          <span>📄 ${name}</span><span style="float:right;color:var(--text3);font-size:10px">${size}</span>
        </div>`;
      });
      html += '</div>';
    }
    html += '</div>';
    panel.innerHTML = html;
  } catch(e) { panel.innerHTML = `<div class="chat-msg system" style="margin:12px">Error: ${e.message}</div>`; }
}

async function viewFileByProject(projectId, filePath) {
  const panel = document.getElementById('files-panel');
  const origHtml = panel.innerHTML;
  try {
    const r = await api('GET', `/project/${projectId}/file?path=${encodeURIComponent(filePath)}`);
    const filename = filePath.split('/').pop();    const highlighted = highlightCode(r.content, filename);
    panel.innerHTML = `<div style="padding:12px">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
        <button class="btn btn-ghost" style="font-size:11px" onclick="browseFiles('${projectId}')">← Back</button>
        <span style="font-size:12px;font-weight:600;color:var(--text2)">${filePath}</span>
        <span style="font-size:10px;color:var(--text3);margin-left:auto">${r.lines} lines</span>
        <button class="btn btn-primary" style="font-size:11px" onclick="openFileEditor('${projectId}','${filePath}')">✏️ Edit</button>
      </div>
      <pre style="font-size:11px;line-height:1.6;overflow-x:auto;background:var(--bg3);padding:10px;border-radius:6px;white-space:pre-wrap;word-break:break-all;color:var(--text)">${highlighted}</pre>
    </div>`;
  } catch(e) {
    panel.innerHTML = origHtml;
    toast('Error reading file: ' + e.message, 'error');
  }
}

async function viewFile(fullPath, el) {
  document.querySelectorAll('.file-item').forEach(e => e.classList.remove('active'));
  el?.classList.add('active');
  const area = document.getElementById('file-content-area');
  if (!area) return;
  area.innerHTML = '<div class="spinner" style="padding:8px"></div>';
  try {
    const r = await api('GET', `/file?path=${encodeURIComponent(fullPath)}`);
    if (r.ok && r.content) {
      const escaped = r.content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const lines = r.content.split('\n').length;
      const fname = fullPath.split('/').pop();
      area.innerHTML = `<div style="font-size:11px;color:var(--text3);padding:6px 0;display:flex;justify-content:space-between">
        <span>📄 ${fname}</span><span>${lines} lines</span>
      </div><div class="code-box" style="max-height:60vh">${escaped}</div>`;
    } else area.innerHTML = '<div style="padding:8px;font-size:12px;color:var(--text3)">Could not read file.</div>';
  } catch { area.innerHTML = '<div style="padding:8px;font-size:12px;color:var(--red)">Error reading file.</div>'; }
}

function showTaskDetail(id) {
  openTaskDetail(id);
}

async function openTaskDetail(taskId) {
  const r = await fetch(`${API}/task/${taskId}`);
  const task = await r.json();
  document.getElementById('task-detail-title').textContent = task.title || task.id;
  const score = task.quality_score || 0;
  const scoreClass = score >= 8 ? 'score-high' : score >= 6 ? 'score-med' : 'score-low';
  document.getElementById('task-detail-meta').innerHTML =
    `Agent: <b>${task.assigned_agent||'—'}</b> &nbsp;|&nbsp;
     Score: <span class="score-badge ${scoreClass}">${score}/10</span> &nbsp;|&nbsp;
     Attempts: <b>${task.attempts||1}</b> &nbsp;|&nbsp;
     Status: <b>${task.status}</b>`;

  let pipelineHtml = '';
  if (task.pipeline_log) {
    try {
      const log = typeof task.pipeline_log === 'string' ? JSON.parse(task.pipeline_log) : task.pipeline_log;
      for (const [stage, data] of Object.entries(log)) {
        const stageScore = data.score ? `<span class="score-badge ${data.score>=8?'score-high':data.score>=6?'score-med':'score-low'}">${data.score}/10</span>` : '';
        pipelineHtml += `<div class="pipeline-stage"><h4>${stage} ${stageScore}</h4><pre>${(data.output||data.result||JSON.stringify(data)).substring(0,800)}</pre></div>`;
      }
    } catch(e) {
      pipelineHtml = `<div class="pipeline-stage"><pre>${String(task.pipeline_log).substring(0,2000)}</pre></div>`;
    }
  }
  if (task.result) {
    pipelineHtml += `<div class="pipeline-stage"><h4>Final Output</h4><pre>${String(task.result).substring(0,1200)}</pre></div>`;
  }
  document.getElementById('task-detail-pipeline').innerHTML = pipelineHtml || '<p style="color:#555">No pipeline log available</p>';
  document.getElementById('task-detail-overlay').style.display = 'block';
}
function closeTaskDetail() { document.getElementById('task-detail-overlay').style.display = 'none'; }
// Close task detail on overlay click
document.getElementById('task-detail-overlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeTaskDetail(); });

