    <!-- Step 3: Review + create -->
    <div class="wizard-step" id="wstep-3">
      <div style="font-size:11px;color:var(--text3);margin-bottom:12px">Step 3 of 3 — Review & Launch</div>
      <div id="wiz-summary" style="background:var(--bg3);border-radius:8px;padding:12px;font-size:12px;margin-bottom:16px;line-height:1.8"></div>
      <div style="font-size:11px;color:var(--text3);margin-bottom:12px">The team will plan the architecture, create tasks, and begin developing immediately.</div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost" style="flex:1" onclick="wizardNext(-1)">← Back</button>
        <button class="btn btn-primary" style="flex:2" id="wiz-create-btn" onclick="wizardCreate()">🚀 Launch Project</button>
