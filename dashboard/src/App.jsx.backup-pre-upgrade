                      <h3 className="text-sm font-semibold text-white">{name}</h3>
                    </div>
                    <p className="text-[11px] text-zinc-500 mt-0.5 ml-4">{meta.roles}</p>
                  </div>
                  <div className="text-right flex-shrink-0">
                    <span className="text-[10px] font-bold px-2 py-0.5 rounded-full" style={{background:`${TIER_COLOR[meta.tier]}18`,color:TIER_COLOR[meta.tier]}}>{meta.tier}</span>
                    {s?.avg_score && <p className="text-lg font-bold mt-1" style={{color:meta.color}}>{s.avg_score.toFixed(1)}<span className="text-xs text-zinc-500">/10</span></p>}
                  </div>
                </div>
                <div className="grid grid-cols-3 gap-2 mt-3">
                  {[{label:'Speed',val:s?.avg_tok_per_sec?`${s.avg_tok_per_sec.toFixed(0)}t/s`:meta.speed},{label:'Context',val:meta.ctx},{label:'Calls',val:s?.total_calls??'0'}].map(({label,val})=>(
                    <div key={label} className="p-2 rounded-lg text-center" style={{background:'rgba(255,255,255,0.025)',border:'1px solid rgba(255,255,255,0.05)'}}>
                      <p className="text-[10px] text-zinc-600">{label}</p>
                      <p className="text-xs font-semibold text-zinc-300 mt-0.5">{val}</p>
                    </div>
                  ))}
                </div>
              </SpotlightCard>
            </AnimatedContent>
          )
        })}
      </div>
      {history.length>0 && (
        <div className="forge-card">
          <h3 className="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-3">Recent Benchmarks</h3>
          <div className="space-y-1 max-h-64 overflow-y-auto forge-scroll">
            {history.map((h,i)=>{
              const col=MODEL_META[h.model]?.color||'#7c3aed'
              return (
                <div key={i} className="flex items-center gap-3 py-1.5 px-2 rounded-lg hover:bg-white/[0.03] transition-all">
                  <div className="w-1.5 h-1.5 rounded-full flex-shrink-0" style={{background:col}}/>
                  <span className="text-[11px] text-zinc-400 flex-1 truncate">{h.model}</span>
                  <span className="text-[11px] text-zinc-600 w-20 truncate">{h.role}</span>
                  <span className="text-[11px] font-medium" style={{color:col}}>{h.tok_per_sec?.toFixed(0)}t/s</span>
                  <span className="text-[11px] text-zinc-600 w-12 text-right">{(h.duration_ms/1000).toFixed(1)}s</span>
                  {h.quality_score!=null && <span className="text-[11px] font-semibold w-10 text-right" style={{color:h.quality_score>=8?'#10b981':h.quality_score>=6?'#d97706':'#ef4444'}}>{h.quality_score}/10</span>}
                </div>
              )
            })}
          </div>
        </div>
      )}
    </div>
  )
}

function Settings() {
  const [vram,setVram]=useState(null)
  useEffect(()=>{ apiFetch('/vram/status').then(d=>{ if(d) setVram(d) }) },[])
  const unload=async(model)=>{ await fetch('/vram/unload',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model})}); apiFetch('/vram/status').then(d=>{ if(d) setVram(d) }) }
  const ROLES=[
    {role:'orchestrator',model:'deepseek-r1:1.5b',tier:'Planner'},
    {role:'architect',model:'deepseek-r1:1.5b',tier:'Planner'},
    {role:'researcher',model:'deepseek-r1:1.5b',tier:'Planner'},
    {role:'coder',model:'qwen2.5-coder:3b',tier:'Workhorse'},
    {role:'refactor',model:'qwen2.5-coder:3b',tier:'Workhorse'},
    {role:'tester',model:'qwen2.5-coder:3b',tier:'Workhorse'},
    {role:'reviewer',model:'deepseek-coder:6.7b',tier:'Auditor'},
    {role:'debugger',model:'deepseek-coder:6.7b',tier:'Auditor'},
    {role:'docs',model:'deepseek-coder:1.3b',tier:'Fast'},
  ]
  return (
    <div className="space-y-6">
      <div>
        <BlurText text="Settings" className="text-2xl font-bold text-white" animateBy="words" delay={60}/>
        <p className="text-sm text-zinc-500 mt-0.5">Agent roles, VRAM control & system config</p>
      </div>
      <div className="forge-card">
        <h3 className="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-4">Agent Role Routing</h3>
        <div className="space-y-2">
          {ROLES.map(r=>(
            <div key={r.role} className="flex items-center gap-3 py-2 px-3 rounded-xl transition-all" style={{background:'rgba(255,255,255,0.02)',border:'1px solid rgba(255,255,255,0.04)'}}>
              <span className="text-[10px] font-bold px-2 py-0.5 rounded-full w-20 text-center flex-shrink-0" style={{background:`${TIER_COLOR[r.tier]}18`,color:TIER_COLOR[r.tier]}}>{r.tier}</span>
              <span className="text-xs font-semibold text-zinc-300 w-24">{r.role}</span>
              <span className="text-xs text-zinc-500 flex-1">{r.model}</span>
              <div className="w-1.5 h-1.5 rounded-full" style={{background:TIER_COLOR[r.tier]}}/>
            </div>
          ))}
        </div>
      </div>
      {vram && (
        <div className="forge-card">
          <h3 className="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-4">VRAM Control</h3>
          {(vram.loaded||[]).length===0
            ? <p className="text-xs text-zinc-600 py-2">No models loaded in VRAM</p>
            : (vram.loaded||[]).map(m=>(
                <div key={m.name} className="flex items-center justify-between py-2 px-3 rounded-xl mb-2" style={{background:'rgba(255,255,255,0.025)',border:'1px solid rgba(255,255,255,0.06)'}}>
                  <div>
                    <p className="text-xs font-semibold text-zinc-300">{m.name}</p>
                    {m.size_vram && <p className="text-[10px] text-zinc-600">{(m.size_vram/1e9).toFixed(2)}GB in VRAM</p>}
                  </div>
                  <button onClick={()=>unload(m.name)} className="px-2.5 py-1 rounded-lg text-[11px] transition-all" style={{background:'rgba(239,68,68,0.1)',color:'#fca5a5',border:'1px solid rgba(239,68,68,0.2)'}}>Unload</button>
                </div>
              ))
          }
        </div>
      )}
      <div className="forge-card">
        <h3 className="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-4">System Info</h3>
        <div className="grid grid-cols-2 gap-2">
          {[['GPU','GTX 1650 SUPER'],['VRAM','4 GB GDDR6'],['RAM','16 GB'],['Inference','100% Local'],['Server','localhost:3737'],['Version','Forge v3.0']].map(([l,v])=>(
            <div key={l} className="flex items-center justify-between px-3 py-2 rounded-lg" style={{background:'rgba(255,255,255,0.02)'}}>
              <span className="text-[11px] text-zinc-600">{l}</span>
              <span className="text-[11px] font-medium text-zinc-400">{v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}

export default function App() {
  const [tab,setTab]=useState('overview')
  const [projects,setProjects]=useState([])
  const [mobile,setMobile]=useState(false)
  const loadP=useCallback(async()=>{ const d=await apiFetch('/projects'); if(Array.isArray(d)) setProjects(d) },[])
  useEffect(()=>{ loadP(); const iv=setInterval(loadP,8000); return()=>clearInterval(iv) },[loadP])
  useEffect(()=>{ const c=()=>setMobile(window.innerWidth<768); c(); window.addEventListener('resize',c); return()=>window.removeEventListener('resize',c) },[])
  const runProject=async(id)=>{ await fetch(`/project/${id}/auto-run`,{method:'POST'}).catch(()=>{}); setTimeout(loadP,1000) }
  return (
    <div className="forge-root">
      <div className="forge-bg">
        <Aurora colorStops={['#0d0018','#000a14','#001209']} amplitude={0.55} blend={0.75} speed={0.2}/>
      </div>
      <div className="forge-shell">
        {!mobile && <Sidebar tab={tab} setTab={setTab} projects={projects}/>}
        <div className="forge-body">
          {mobile && (
            <nav className="flex gap-1.5 px-3 pt-3 overflow-x-auto forge-scroll">
              {NAV.map(n=>(
                <button key={n.id} onClick={()=>setTab(n.id)} className={`flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-medium border transition-all ${tab===n.id?'bg-violet-500/15 text-violet-200 border-violet-500/25':'text-zinc-500 border-white/[0.06]'}`}>
                  {n.icon} {n.label}
                </button>
              ))}
            </nav>
          )}
          <main className="forge-main">
            {tab==='overview'&&<Overview projects={projects} onRun={runProject}/>}
            {tab==='pipeline'&&<Pipeline projects={projects}/>}
            {tab==='chat'    &&<Chat/>}
            {tab==='models'  &&<Models/>}
            {tab==='settings'&&<Settings/>}
          </main>
        </div>
      </div>
    </div>
  )
}
