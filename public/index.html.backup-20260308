// ── Agent Collaboration Status ─────────────────────────────────────────────
const AGENT_ROLES = ['research','architect','coder','reviewer','tester','debugger','refactor','security','docs'];
let _activeAgents = {};

function updateAgentStatus(role, status, score) {
  if (!role) return;
  _activeAgents[role] = { status, score, ts: Date.now() };
  renderAgentBar();
}

function renderAgentBar() {
  const bar = document.getElementById('agent-status-bar');
  if (!bar) return;
  bar.innerHTML = AGENT_ROLES.map(role => {
    const a = _activeAgents[role];
    const color = !a ? '#1a1a2e' : a.status === 'running' ? '#2a1a3e' : a.status === 'done' ? '#1a3a1a' : '#3a1a1a';
    const textColor = !a ? '#333' : a.status === 'running' ? '#c678dd' : a.status === 'done' ? '#4caf50' : '#f44336';
    const icon = !a ? '○' : a.status === 'running' ? '⟳' : a.status === 'done' ? '✓' : '✗';
    return `<div style="background:${color};color:${textColor};padding:4px 8px;border-radius:4px;font-size:11px;font-family:monospace;">
      ${icon} ${role}${a && a.score ? ' ' + a.score : ''}
    </div>`;
  }).join('');
}

// ── Model VRAM Hint ────────────────────────────────────────────────────────
function updateModelVramHint(model) {
  const hints = {
    'phi3.5-forge': { mb: 2200, ctx: 4096, color: '#4caf50', msg: 'Fits perfectly in 4GB VRAM. Best quality for phi3.5.' },
    'phi3.5:latest': { mb: 2200, ctx: 4096, color: '#4caf50', msg: 'Same as forge model.' },
    'qwen2.5-coder:1.5b': { mb: 1000, ctx: 16384, color: '#ff9800', msg: '16K context. Good for large files. Slightly lower quality.' },
    'deepseek-coder:1.3b': { mb: 800, ctx: 24576, color: '#ff9800', msg: '24K context. Most context space. Weaker reasoning.' }
  };
  const h = hints[model] || { mb: 0, ctx: 4096, color: '#888', msg: 'Unknown model' };
  const vramPct = Math.round(h.mb / 4096 * 100);
  const hint = document.getElementById('vram-hint');
  if (hint) hint.innerHTML =
    `<span style="color:${h.color}">VRAM: ${h.mb}MB (${vramPct}%) | Max ctx: ${h.ctx} tokens</span><br>
     <span style="color:#888">${h.msg}</span>`;
}

// ── Header VRAM Bar ────────────────────────────────────────────────────────
async function updateVramBar() {
  try {
    const r = await fetch(`${API}/system/vram`);
    const v = await r.json();
    if (v.available) {
      const pct = v.totalMB > 0 ? Math.round(v.usedMB / v.totalMB * 100) : 0;
      const fill = document.getElementById('vram-fill');
      const label = document.getElementById('vram-label');
      if (fill) {
        fill.style.width = pct + '%';
        fill.style.background = pct > 90 ? '#f44336' : pct > 75 ? '#ff9800' : '#7c6af5';
      }
      if (label) label.textContent = `${v.usedMB}/${v.totalMB}MB`;
    }
  } catch(e) {}
}

