const COMMAND_PATTERNS = [
  { pattern: /^(add|create|implement|build)\s+(.+)/i, action: 'add_task' },
  { pattern: /^fix\s+(.+)/i, action: 'fix_task' },
  { pattern: /^(make|convert)\s+(.+)\s+production.?ready/i, action: 'production_ready' },
  { pattern: /^(run|execute)\s+tests?/i, action: 'run_tests' },
  { pattern: /^analyze\s+(.+)/i, action: 'analyze_project' },
  { pattern: /^standup/i, action: 'standup' },
  { pattern: /^(deploy|dockerfile)/i, action: 'deploy_prep' },
  { pattern: /^backup/i, action: 'backup' },
];

async function parseAndExecuteCommand(message, projectId) {
  for (const { pattern, action } of COMMAND_PATTERNS) {
    const match = message.match(pattern);
    if (!match) continue;

    if (action === 'add_task' && projectId) {
      const taskDesc = match[2] || match[1];
      const r = await fetch(`${API}/project/${projectId}/expand`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ hint: taskDesc })
      });
      const d = await r.json();
      return `🔨 Created task: "${taskDesc}" — ${d.tasksAdded || 0} new tasks added to queue`;
    }
    if (action === 'fix_task' && projectId) {
      const r = await fetch(`${API}/project/${projectId}/retry-low-quality`, { method: 'POST' });
      const d = await r.json();
      return `🔧 Retrying ${d.reset || 0} low-quality tasks for fixing`;
    }
    if (action === 'production_ready' && projectId) {
      await fetch(`${API}/project/${projectId}/deploy-prep`, { method: 'POST' });
      return `📦 Generated Dockerfile, docker-compose.yml, .env.example, DEPLOY.md`;
    }
    if (action === 'run_tests' && projectId) {
      const r = await fetch(`${API}/project/${projectId}/run-tests-v2`, { method: 'POST' });
      const d = await r.json();
      return `🧪 Tests: ${d.summary?.totalPassed||0} passed, ${d.summary?.totalFailed||0} failed`;
    }
    if (action === 'standup') {
      const r = await fetch(`${API}/standup`);
      const d = await r.json();
      return d.standup || 'No standup data yet';
    }
    if (action === 'deploy_prep' && projectId) {
      await fetch(`${API}/project/${projectId}/deploy-prep`, { method: 'POST' });
      return `🐳 Deployment files generated (Dockerfile, docker-compose.yml)`;
    }
    if (action === 'backup' && projectId) {
      const r = await fetch(`${API}/project/${projectId}/backup`, { method: 'POST' });
      const d = await r.json();
      return `💾 Backup created: ${d.backupFile || 'complete'}`;
    }
  }
  return null; // Not a command
}

async function heroBuild() {
  const input = document.getElementById('hero-build-input');
  const description = input?.value?.trim();
  if (!description || description.length < 5) {
    return toast('Describe what you want to build first!', 'error');
  }

  input.disabled = true;
  const btn = input.nextElementSibling;
  if (btn) { btn.disabled = true; btn.textContent = '⟳ Building...'; }

  toast('⚡ Forge is planning your project...', 'info');

  try {
    const r = await api('POST', '/build', { description, autoRun: true });

    if (r.projectId) {
      toast(`🚀 Building "${r.name}"! ${r.totalTasks} tasks started.`, 'success');
      input.value = '';

      // Switch to the new project view
      await loadProjects();
      const newProj = projects.find(p => p.id === r.projectId);
      if (newProj) {
        selectedProject = newProj;
        await loadProjects();
        await selectProject(newProj.projectId || newProj.id);
        showView('project');
        switchTab('chat'); // show live build progress
      }

      // Show build info in auto-build panel
      setTimeout(() => {
        const panel = document.getElementById('auto-build-panel');
        if (panel) panel.style.display = 'block';
        addAutoBuildLog(`🚀 Building: "${r.name}"`);
        addAutoBuildLog(`📋 ${r.totalTasks} tasks across ${r.epics?.length} epics`);
        (r.epics || []).forEach(e => addAutoBuildLog(`  • ${e.title} (${e.tasks?.length} tasks)`));
      }, 500);
    } else {
      toast('Error: ' + (r.error || 'Unknown error'), 'error');
    }
  } catch(e) {
    toast('Build failed: ' + e.message, 'error');
  } finally {
    if (input) input.disabled = false;
    if (btn) { btn.disabled = false; btn.textContent = '⚡ Build It'; }
  }
}

async function sendChat() {
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');
  const role = selectedAgentRole;
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  input.style.height = 'auto';

  // Check for command shortcuts
  const commandResult = await parseAndExecuteCommand(msg, selectedProject?.id);
  if (commandResult) {
    appendChatMessage('user', msg);
    appendChatMessage('assistant', commandResult);
    return;
  }

  const projectId = selectedProject?.id;
  const msgs = document.getElementById('chat-messages');
  if (input) input.disabled = true;
  if (sendBtn) sendBtn.disabled = true;

  // Add user message bubble
  const userDiv = document.createElement('div');
  userDiv.className = 'chat-msg user-msg';
  userDiv.innerHTML = `<div class="msg-avatar">👤</div><div class="msg-content">${escapeHtml(msg)}</div>`;
  msgs.appendChild(userDiv);
  saveChatMessage(projectId, 'user', msg);

  // Detect if user is asking an agent-specific question (like "explain X" to coder)
  const isDirectAgentQuery = role !== 'orchestrator' && /^(explain|what|how|why|describe|show|list)/i.test(msg);

  try {
    if (isDirectAgentQuery) {
      const thinkDiv = document.createElement('div');
      thinkDiv.className = 'chat-msg assist-msg';
      thinkDiv.innerHTML = `<div class="msg-avatar">⚡</div><div class="msg-content"><span class="typing-indicator">●●●</span></div>`;
      msgs.appendChild(thinkDiv);
      msgs.scrollTop = msgs.scrollHeight;
      try {
        const payload = { task: msg, useMultipass: false };
        if (projectId) payload.projectId = projectId;
        const r = await api('POST', `/agent/${role}`, payload);
        const contentEl = thinkDiv.querySelector('.msg-content');
        const text = r.output || 'No response';
        contentEl.textContent = text;
        saveChatMessage(projectId, 'assistant', text);
      } catch(e) {
        thinkDiv.querySelector('.msg-content').textContent = '❌ Error: ' + e.message;
      }
    } else {
      await sendChatStreaming(msg, projectId, msgs);
    }
    msgs.scrollTop = msgs.scrollHeight;
  } finally {
    if (input) { input.disabled = false; input.focus(); }
    if (sendBtn) sendBtn.disabled = false;
  }
}

async function sendChatStreaming(message, projectId, messagesEl) {
  if (!messagesEl) messagesEl = document.getElementById('chat-messages');

  const assistDiv = document.createElement('div');
  assistDiv.className = 'chat-msg assist-msg';
  assistDiv.innerHTML = `<div class="msg-avatar">⚡</div><div class="msg-content" id="streaming-response"><span class="typing-indicator">●●●</span></div>`;
  messagesEl.appendChild(assistDiv);
  messagesEl.scrollTop = messagesEl.scrollHeight;

  const contentEl = document.getElementById('streaming-response');
  let fullText = '';

  const inp = document.getElementById('chat-input');
  const btn = document.getElementById('chat-send');
  if (inp) inp.disabled = true;
  if (btn) btn.disabled = true;

  try {
    const response = await fetch(`${API}/chat/stream`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message, projectId })
    });

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    contentEl.textContent = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      const chunk = decoder.decode(value, { stream: true });
      for (const line of chunk.split('\n')) {
        if (line.startsWith('data: ')) {
          try {
            const d = JSON.parse(line.slice(6));
            if (d.token) {
              fullText += d.token;
              contentEl.textContent = fullText;
              messagesEl.scrollTop = messagesEl.scrollHeight;
            }
            if (d.done && d.type === 'build_started' && d.projectId) {
              handleBuildStarted(d);
            }
          } catch {}
        }
      }
    }
    contentEl.id = '';
    saveChatMessage(projectId, 'assistant', fullText || contentEl.textContent);
  } catch(e) {
    contentEl.textContent = `❌ Error: ${e.message}`;
  } finally {
    if (inp) { inp.disabled = false; inp.focus(); }
    if (btn) btn.disabled = false;
  }
}

async function handleBuildStarted(data) {
  await loadProjects();
  const proj = projects.find(p => p.id === data.projectId);
  if (proj) {
    selectedProject = proj;
    renderChatSuggestions(proj.id);
    setTimeout(() => {
      const panel = document.getElementById('auto-build-panel');
      if (panel) {
        panel.style.display = 'block';
        addAutoBuildLog(`🚀 Building "${data.name || proj.name}"`);
      }
      switchTab('chat');
    }, 400);
  }
}

function renderChatSuggestions(projectId) {
  const container = document.getElementById('chat-suggestions-container');
  if (!container) return;
  const suggestions = projectId ? [
    '⚡ Run all tasks',
    '🔍 What tasks are pending?',
    '📊 Show project quality score',
    '🏗 Scaffold starter files',
    '▶ Run and test the project',
    '🔄 Improve low-quality tasks'
  ] : [
    'Build a REST API with authentication',
    'Create a CLI tool for file management',
    'Write a web scraper in Python',
    'Build a real-time chat app',
    'Create a Discord bot'
  ];
  container.innerHTML = `<div class="chat-suggestions">${suggestions.map(s => `<span class="suggestion-chip" onclick="useSuggestion('${s.replace(/'/g, "\\'")}')">${s}</span>`).join('')}</div>`;
}

function useSuggestion(text) {
  const input = document.getElementById('chat-input');
  if (input) { input.value = text; input.focus(); input.dispatchEvent(new Event('input')); }
}

function initChatInput() {
  const input = document.getElementById('chat-input');
  if (!input) return;
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 150) + 'px';
  });
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); }
  });
}

initChatInput();
renderChatSuggestions(null);

// ── Log viewer ─────────────────────────────────────────────────────────────
async function loadLog(which) {
  currentLog = which;
  const el = document.getElementById('log-content');
  el.textContent = 'Loading...';
  try {
    const r = await api('GET', '/runner/status');
    const logText = r.recentLog || '(empty)';
    el.innerHTML = logText.split('\n').map(l => {
      if (l.includes('[err]') || l.includes('Error') || l.includes('❌')) return `<span class="log-err">${l}</span>`;
      if (l.includes('✅') || l.includes('[1]') || l.includes('✓')) return `<span class="log-ok">${l}</span>`;
      if (l.includes('[warn]') || l.includes('⚠')) return `<span class="log-warn">${l}</span>`;
      return l;
    }).join('\n');
    el.scrollTop = el.scrollHeight;
  } catch { el.textContent = 'Could not load logs.'; }
}

// ── Tabs ───────────────────────────────────────────────────────────────────
function switchTab(tab) {
  ['chat','logs','files','live','search','metrics','examples'].forEach(t => {
    const panelMap = { chat:'panel-chat', search:'panel-search', logs:'panel-logs', files:'panel-files', live:'panel-live', metrics:'panel-metrics', examples:'panel-examples' };
    const panel = document.getElementById(panelMap[t]);
    if (panel) panel.style.display = t === tab ? 'flex' : 'none';
    const tabBtn = document.getElementById('tab-'+t);
    if (tabBtn) tabBtn.classList.toggle('active', t === tab);
  });
  if (tab === 'logs') loadLog(currentLog);
  if (tab === 'files' && currentBrowseProject) browseFiles(currentBrowseProject);
  if (tab === 'metrics') loadMetrics();
  if (tab === 'examples') renderExamples();
}

async function loadMetrics() {
  const el = document.getElementById('metrics-content');
  if (!el) return;
  el.innerHTML = '<div style="color:var(--text3)">Loading…</div>';
  try {
    // Fetch capabilities and legacy metrics in parallel
    const [cap, m] = await Promise.all([
      api('GET', '/capabilities').catch(() => null),
      api('GET', '/metrics').catch(() => null)
    ]);
    let html = '';

    // ── Capabilities: Grade Badge + Quality Overview ──
    if (cap && (cap.grade || cap.avgQuality != null)) {
      const grade = cap.grade || 'B';
      const avgQ = cap.avgQuality != null ? Number(cap.avgQuality).toFixed(1) : '—';
      const best = cap.bestScore != null ? cap.bestScore : '—';
      const done = cap.totalTasksDone ?? 0;
      const hqRate = cap.highQualityRate != null ? Math.round(cap.highQualityRate * 100) : 0;
      const qPct = avgQ !== '—' ? Math.min(100, Math.round(avgQ * 10)) : 0;

      html += `<div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;padding:14px;background:var(--bg3);border-radius:10px;border:1px solid var(--border2)">
        <div class="grade-badge-large grade-${grade}">${grade}</div>
        <div style="flex:1;min-width:0">
          <div style="font-size:22px;font-weight:800;color:var(--text);line-height:1">${avgQ}<span style="font-size:13px;font-weight:400;color:var(--text3)">/10 avg quality</span></div>
          <div style="margin:8px 0 4px;background:var(--bg);border-radius:4px;height:8px;overflow:hidden">
            <div style="height:100%;background:linear-gradient(90deg,var(--accent2),var(--accent));width:${qPct}%;border-radius:4px;transition:width 0.8s"></div>
          </div>
          <div style="font-size:11px;color:var(--text3)">Best: <b style="color:var(--green)">${best}/10</b> &nbsp;·&nbsp; Done: <b style="color:var(--accent)">${done}</b> tasks &nbsp;·&nbsp; High Quality: <b style="color:var(--blue)">${hqRate}%</b></div>
        </div>
      </div>`;

      // Score distribution
      const dist = cap.scoreDistribution || {};
      const excellent = dist.excellent ?? 0;
      const good = dist.good ?? 0;
      const acceptable = dist.acceptable ?? 0;
      const poor = dist.poor ?? 0;
      const distTotal = excellent + good + acceptable + poor || 1;
      html += `<div style="font-weight:600;margin-bottom:8px;font-size:12px">📊 Score Distribution</div>`;
      [
        { label: 'Excellent (9–10)', count: excellent, color: '#4caf50' },
        { label: 'Good (7–8)', count: good, color: '#007bff' },
        { label: 'Acceptable (5–6)', count: acceptable, color: '#ff9800' },
        { label: 'Poor (< 5)', count: poor, color: '#f44336' },
      ].forEach(b => {
        const pct = Math.round((b.count / distTotal) * 100);
        html += `<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:11px">
          <span style="width:120px;color:var(--text2);flex-shrink:0">${b.label}</span>
          <div style="flex:1;background:var(--bg3);border-radius:3px;height:12px;overflow:hidden">
            <div style="background:${b.color};width:${pct}%;height:100%;border-radius:3px;transition:width 0.8s"></div>
          </div>
          <span style="width:32px;text-align:right;color:var(--text3)">${b.count}</span>
        </div>`;
      });

      // Top achievements
      if (cap.topAchievements?.length) {
        html += `<div style="font-weight:600;margin:12px 0 6px;font-size:12px">🏆 Achievements</div>`;
        cap.topAchievements.slice(0, 5).forEach(a => {
          html += `<div style="font-size:11px;color:var(--text2);padding:3px 0;border-bottom:1px solid var(--border)">🎯 ${a}</div>`;
        });
      }

      // Agent performance grid
      if (cap.agentPerformance && Object.keys(cap.agentPerformance).length) {
        html += `<div style="font-weight:600;margin:12px 0 8px;font-size:12px">🤖 Agent Performance</div>`;
        html += `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:4px">`;
        Object.entries(cap.agentPerformance).slice(0, 9).forEach(([agent, score]) => {
          const s = Number(score);
          const c = s >= 8 ? 'var(--green)' : s >= 6 ? 'var(--yellow)' : 'var(--red)';
          html += `<div style="background:var(--bg3);border-radius:6px;padding:6px 8px;text-align:center;border:1px solid var(--border)">
            <div style="font-size:15px;font-weight:700;color:${c}">${isNaN(s)?'—':s.toFixed(1)}</div>
            <div style="font-size:10px;color:var(--text3);margin-top:2px">${agent}</div>
          </div>`;
        });
        html += `</div>`;
      }

      html += `<div style="border-top:1px solid var(--border);margin:14px 0"></div>`;
    }

    // ── Legacy /metrics data ──
    if (m) {
      if (m.scoreHistogram && m.scoreHistogram.length) {
        const max = Math.max(...m.scoreHistogram.map(r => r.count), 1);
        html += `<div style="font-weight:600;margin-bottom:8px;font-size:12px">Score Histogram</div><div style="display:grid;gap:3px">`;
        for (const r of m.scoreHistogram) {
          const pct = Math.round((r.count / max) * 100);
          html += `<div style="display:flex;align-items:center;gap:8px;font-size:11px"><span style="width:20px;text-align:right">${r.score}</span><div style="flex:1;background:var(--bg3);border-radius:3px;height:14px"><div style="background:var(--accent);width:${pct}%;height:100%;border-radius:3px"></div></div><span style="width:24px;color:var(--text3)">${r.count}</span></div>`;
        }
        html += `</div>`;
      }
      const mins = Math.round((m.avgDurationMs || 0) / 60000);
      const secs = Math.round(((m.avgDurationMs || 0) % 60000) / 1000);
      html += `<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px">
        <div style="background:var(--bg3);border-radius:6px;padding:10px;text-align:center"><div style="font-size:18px;font-weight:700;color:var(--accent)">${mins}m ${secs}s</div><div style="font-size:10px;color:var(--text3);margin-top:2px">avg task time</div></div>
        <div style="background:var(--bg3);border-radius:6px;padding:10px;text-align:center"><div style="font-size:18px;font-weight:700;color:var(--green)">${(m.agentStats || []).reduce((s, a) => s + a.count, 0)}</div><div style="font-size:10px;color:var(--text3);margin-top:2px">tasks done</div></div>
      </div>`;
      if (m.tasksPerHour && m.tasksPerHour.length) {
        html += `<div style="font-weight:600;margin:14px 0 8px;font-size:12px">Tasks/Hour</div><div style="display:flex;flex-wrap:wrap;gap:4px">`;
        for (const r of m.tasksPerHour.slice(0, 12).reverse()) {
          html += `<div style="background:var(--bg3);border-radius:4px;padding:3px 7px;font-size:10px;color:var(--text2)">${r.hour?.slice(11) || r.hour} <b style="color:var(--accent)">${r.count}</b></div>`;
        }
        html += `</div>`;
      }
    }

    el.innerHTML = html || '<div style="color:var(--text3)">No metrics yet — run some tasks first.</div>';

    // ── Quick Actions ──
    const qaDiv = document.createElement('div');
    qaDiv.style.cssText = 'margin-top:14px;padding-top:14px;border-top:1px solid var(--border)';
    qaDiv.innerHTML = `<div style="font-weight:600;margin-bottom:8px;font-size:12px">⚡ Quick Actions</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-ghost" style="font-size:11px" onclick="retryLowQuality()">🔁 Retry Low Quality</button>
        <button class="btn btn-ghost" style="font-size:11px" onclick="runImproveLoop()">🚀 Run Improve Loop</button>
        <button class="btn btn-ghost" style="font-size:11px" onclick="loadMetrics()">↺ Refresh Metrics</button>
      </div>`;
    el.appendChild(qaDiv);

    // ── Top Patterns ──
    try {
      const patterns = await api('GET', '/patterns').catch(() => null);
      if (patterns && (patterns.patterns || patterns.topPatterns || []).length) {
        const list = patterns.patterns || patterns.topPatterns || [];
        const pDiv = document.createElement('div');
        pDiv.style.cssText = 'margin-top:10px';
        let pHtml = `<div style="font-weight:600;margin-bottom:6px;font-size:12px">📐 Top Patterns Used</div>`;
        list.slice(0, 6).forEach(p => {
          const name = typeof p === 'string' ? p : (p.name || p.pattern || JSON.stringify(p));
          const count = typeof p === 'object' ? (p.count || p.uses || '') : '';
          pHtml += `<div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border);font-size:11px">
            <span style="color:var(--text2)">📐 ${name}</span>${count ? `<span style="color:var(--accent)">${count}×</span>` : ''}
          </div>`;
        });
        pDiv.innerHTML = pHtml;
        el.appendChild(pDiv);
      }
    } catch {}

    // ── Sparkline ──
    try {
      const m2 = await api('GET', '/stats');
      const recentScores = (m2.recentTasks || []).map(t => t.quality_score || 0).filter(s => s > 0).slice(-20);
      if (recentScores.length > 2) {
        const canvas = document.createElement('canvas');
        canvas.className = 'chart-canvas';
        canvas.style.cssText = 'width:100%;height:80px;display:block;margin-bottom:12px';
        canvas.width = 300; canvas.height = 80;
        el.prepend(canvas);
        const ctx2 = canvas.getContext('2d');
        const maxV = 10, minV = 0, padX = 8, padY = 8;
        const w = canvas.width - padX * 2, h = canvas.height - padY * 2;
        const step = w / (recentScores.length - 1);
        ctx2.strokeStyle = '#7c6aff';
        ctx2.lineWidth = 2;
        ctx2.beginPath();
        recentScores.forEach((v, i) => {
          const x = padX + i * step;
          const y = padY + h - (v - minV) / (maxV - minV) * h;
          i === 0 ? ctx2.moveTo(x, y) : ctx2.lineTo(x, y);
        });
        ctx2.stroke();
        ctx2.lineTo(padX + (recentScores.length - 1) * step, padY + h);
        ctx2.lineTo(padX, padY + h);
        ctx2.closePath();
        ctx2.fillStyle = 'rgba(124,106,255,0.15)';
        ctx2.fill();
      }
    } catch {}
    loadKnowledgeGraph();
  } catch (e) {
    el.innerHTML = `<div style="color:var(--error)">Error: ${e.message}</div>`;
  }
}

