{
  "scheduleNodes": [
    {
      "name": "Daily Self-Improve (3am)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": { "rule": { "interval": [{"field": "cronExpression", "expression": "0 3 * * *"}] } },
      "webhook": "POST http://localhost:3737/schedule/improve"
    },
    {
      "name": "6hr Memory Compress",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": { "rule": { "interval": [{"field": "hours", "value": 6}] } },
      "webhook": "POST http://localhost:3737/schedule/compress-memory"
    }
  ]
}
