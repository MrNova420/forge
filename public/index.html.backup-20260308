  const toastMsg2 = selectedProject
    ? `Running next task for "${selectedProject.name}" — this takes 5-10 min...`
    : 'Running next pending task — this takes 5-10 min...';
  toast(toastMsg2, 'info');
  try {
    const payload = selectedProject ? { projectId: selectedProject.id } : {};
    const r = await api('POST', '/task/run-next', payload);
    if (r.taskId) {
      toast(`✅ Task done! Score: ${r.qualityScore}/10`, 'success');
    } else if (r.message) {
      toast(r.message, 'info');
    } else if (r.error) {
      toast('Error: ' + r.error, 'error');
    }
  } catch(e) { toast('Task failed: ' + e.message, 'error'); }
  finally {
    // Always refresh so the button re-renders fresh and enabled
    await refreshAll();
  }
}

